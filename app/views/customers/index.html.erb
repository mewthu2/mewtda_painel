<% title 'Clientes' %>

<div class="customers-wrapper">

  <%# Filtros %>
  <%= form_tag(customers_path, method: 'get') do %>
    <div class="customers-filters">

      <div class="customers-filters__row">
        <div class="customers-filters__field">
          <label>Buscar</label>
          <%= text_field_tag :search, params[:search], class: 'customers-filters__input', placeholder: 'Nome ou e-mail...' %>
        </div>
        <div class="customers-filters__field">
          <label>Telefone</label>
          <%= text_field_tag :phone, params[:phone], class: 'customers-filters__input', placeholder: '+55...' %>
        </div>
        <div class="customers-filters__field customers-filters__field--sm">
          <label>Min. de compras</label>
          <%= number_field_tag :min_orders, params[:min_orders], class: 'customers-filters__input', placeholder: 'Ex: 3', min: 1 %>
        </div>
        <div class="customers-filters__field">
          <label>Comprou o produto</label>
          <%= text_field_tag :product_name, params[:product_name], class: 'customers-filters__input', placeholder: 'Nome do produto...' %>
        </div>
      </div>

      <div class="customers-filters__row customers-filters__row--bottom">
        <div class="customers-filters__quick">
          <span class="customers-filters__quick-label">Filtros rápidos:</span>

          <div class="customers-filters__inactive-wrap">
            <%= number_field_tag :inactive_days, params[:inactive_days],
                class: "customers-filters__input customers-filters__input--days #{'is-active' if params[:inactive_days].present?}",
                placeholder: 'Dias', min: 1, id: 'inactive_days_field' %>
            <button type="submit" name="inactive_days_submit" value="1"
                    class="customers-btn customers-btn--quick <%= 'customers-btn--quick-active' if params[:inactive_days].present? %>"
                    id="inactive_btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Sem compras há <span id="inactive_label"><%= params[:inactive_days].present? ? "#{params[:inactive_days]}d" : "? dias" %></span>
            </button>
          </div>

          <%= link_to customers_path(params.permit(:search, :phone, :min_orders, :product_name, :inactive_days).merge(maderite: params[:maderite].present? ? nil : '1')),
              class: "customers-btn customers-btn--quick #{'customers-btn--quick-active' if params[:maderite].present?}" do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
            </svg>
            Coleção Maderite
          <% end %>
        </div>

        <div class="customers-filters__actions">
          <%= button_tag class: 'customers-btn customers-btn--primary', name: '' do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 10.607z" />
            </svg>
            Filtrar
          <% end %>
          <%= link_to export_xlsx_customers_path(params.permit(:search, :phone, :min_orders, :product_name, :inactive_days, :maderite)),
              class: 'customers-btn customers-btn--export' do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
            </svg>
            Exportar XLSX
          <% end %>
          <%= link_to customers_path, class: 'customers-btn customers-btn--secondary' do %>
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
            Limpar
          <% end %>
        </div>
      </div>

    </div>
  <% end %>

  <%# Tabela %>
  <div class="customers-table-wrap">
    <table class="customers-table">
      <thead>
        <tr>
          <th>Cliente</th>
          <th>E-mail</th>
          <th>Telefone</th>
          <th class="text-center">Pedidos</th>
          <th class="text-center">Cadastrado em</th>
          <th class="text-center">Detalhes</th>
        </tr>
      </thead>
      <tbody>
        <% if @customers.empty? %>
          <tr>
            <td colspan="6" class="customers-table__empty">Nenhum cliente encontrado.</td>
          </tr>
        <% else %>
          <% @customers.each do |customer| %>
            <% full_name    = [customer.first_name, customer.last_name].compact.join(' ').presence || customer.name.presence || 'Sem nome' %>
            <% initials     = [customer.first_name&.first, customer.last_name&.first].compact.join('').upcase.presence || '?' %>
            <% orders_count = customer.try(:orders_count).to_i %>
            <tr>
              <td class="customers-table__name">
                <span class="customers-avatar"><%= initials %></span>
                <span class="customers-table__fullname"><%= full_name %></span>
              </td>
              <td>
                <% if customer.email.present? %>
                  <a href="mailto:<%= customer.email %>" class="customers-link"><%= customer.email %></a>
                <% else %>
                  <span class="customers-badge customers-badge--empty">—</span>
                <% end %>
              </td>
              <td>
                <% if customer.phone.present? %>
                  <a href="tel:<%= customer.phone %>" class="customers-link customers-link--phone">
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.338c0-1.36.876-2.572 2.19-2.938l1.217-.338a2.25 2.25 0 012.517 1.031l.956 1.67a2.25 2.25 0 01-.481 2.83l-.534.445c-.188.157-.26.42-.16.644.367.82.974 1.906 1.84 2.773.867.867 1.952 1.474 2.773 1.841.225.1.487.028.644-.16l.445-.534a2.25 2.25 0 012.83-.481l1.67.956a2.25 2.25 0 011.031 2.517l-.338 1.217c-.366 1.314-1.578 2.19-2.938 2.19C8.552 21.75 2.25 15.448 2.25 6.338z" />
                    </svg>
                    <%= customer.phone %>
                  </a>
                <% else %>
                  <span class="customers-badge customers-badge--empty">—</span>
                <% end %>
              </td>
              <td class="text-center">
                <span class="customers-badge customers-badge--orders"><%= orders_count %></span>
              </td>
              <td class="text-center"><%= customer.created_at.strftime('%d/%m/%Y') %></td>
              <td class="text-center">
                <button class="customers-btn customers-btn--details"
                        onclick="openCustomerModal('<%= customer.id %>')">
                  <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.964-7.178z" />
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                  </svg>
                  Ver detalhes
                </button>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
      <tfoot>
        <tr>
          <th colspan="6"><%= page_entries_info @customers %></th>
        </tr>
      </tfoot>
    </table>
  </div>

  <%= will_paginate @customers, list_classes: %w[pagination justify-content-center mt-lg], inner_window: 1 %>

</div>

<%# Modal — oculto até o fetch completar %>
<div id="customer-modal-overlay" class="cmodal-overlay" onclick="closeCustomerModal()">
  <div class="cmodal" onclick="event.stopPropagation()">

    <%# Estado: loading (visível por padrão até os dados chegarem) %>
    <div id="cmodal-loading" class="cmodal-loading">
      <div class="cmodal-loading__spinner"></div>
      <span>Carregando dados do cliente...</span>
    </div>

    <%# Estado: conteúdo (oculto até os dados chegarem) %>
    <div id="cmodal-content" style="display:none; flex-direction:column; overflow:hidden; flex:1;">
      <div class="cmodal__header">
        <div class="cmodal__avatar" id="cmodal-avatar"></div>
        <div>
          <h2 class="cmodal__name" id="cmodal-name"></h2>
          <span class="cmodal__shopify-id" id="cmodal-shopify-id"></span>
        </div>
        <button class="cmodal__close" onclick="closeCustomerModal()">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <div class="cmodal__body">
        <div class="cmodal__info-grid">
          <div class="cmodal__info-item">
            <span class="cmodal__info-label">E-mail</span>
            <span class="cmodal__info-value" id="cmodal-email"></span>
          </div>
          <div class="cmodal__info-item">
            <span class="cmodal__info-label">Telefone</span>
            <span class="cmodal__info-value" id="cmodal-phone"></span>
          </div>
          <div class="cmodal__info-item">
            <span class="cmodal__info-label">Cadastrado em</span>
            <span class="cmodal__info-value" id="cmodal-created"></span>
          </div>
          <div class="cmodal__info-item">
            <span class="cmodal__info-label">Total de pedidos</span>
            <span class="cmodal__info-value" id="cmodal-orders-count"></span>
          </div>
        </div>

        <div class="cmodal__section-title">Pedidos</div>
        <div id="cmodal-orders-list" class="cmodal__orders"></div>
      </div>
    </div>

  </div>
</div>

<script>
  (function() {
    var daysField = document.getElementById('inactive_days_field');
    var daysLabel = document.getElementById('inactive_label');
    if (daysField && daysLabel) {
      daysField.addEventListener('input', function() {
        daysLabel.textContent = daysField.value.trim() ? daysField.value.trim() + 'd' : '? dias';
      });
    }
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeCustomerModal();
    });
  })();

  function openCustomerModal(customerId) {
    var overlay  = document.getElementById('customer-modal-overlay');
    var loading  = document.getElementById('cmodal-loading');
    var content  = document.getElementById('cmodal-content');

    // Mostra apenas o spinner, esconde conteúdo
    loading.style.display  = 'flex';
    content.style.display  = 'none';
    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';

    fetch('/painel/customers/' + customerId + '/details', {
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      var customer = data.customer;
      var orders   = data.orders || [];
      var name     = customer.name || 'Sem nome';

      var initials = name.split(' ').slice(0,2).map(function(w){ return w[0] || ''; }).join('').toUpperCase();
      document.getElementById('cmodal-avatar').textContent       = initials || '?';
      document.getElementById('cmodal-name').textContent         = name;
      document.getElementById('cmodal-shopify-id').textContent   = 'ID Shopify: ' + (customer.shopify_id || '—');
      document.getElementById('cmodal-email').textContent        = customer.email || '—';
      document.getElementById('cmodal-phone').textContent        = customer.phone || '—';
      document.getElementById('cmodal-created').textContent      = customer.created_at || '—';
      document.getElementById('cmodal-orders-count').textContent = orders.length + ' pedido(s)';

      var list = document.getElementById('cmodal-orders-list');
      list.innerHTML = '';

      if (orders.length === 0) {
        list.innerHTML = '<p class="cmodal__empty">Nenhum pedido encontrado para este cliente.</p>';
      } else {
        orders.forEach(function(order) {
          var shopifyUrl = 'https://admin.shopify.com/store/henrribrasil/orders/' + order.shopify_id;
          var total      = order.total > 0 ? 'R$ ' + parseFloat(order.total).toFixed(2).replace('.', ',') : '—';
          var items      = order.items || [];

          var card = document.createElement('div');
          card.className = 'cmodal__order-card';

          var header = document.createElement('div');
          header.className = 'cmodal__order-header';
          header.innerHTML =
            '<a href="' + shopifyUrl + '" target="_blank" class="cmodal__order-number" onclick="event.stopPropagation()">' + (order.number || '—') + '</a>' +
            '<div class="cmodal__order-meta">' +
              '<span>' + (order.date || '—') + '</span>' +
              '<span>' + order.items_count + ' item(s)</span>' +
              '<span class="cmodal__order-total">' + total + '</span>' +
            '</div>' +
            '<svg class="cmodal__order-toggle" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/></svg>';

          var itemsWrap = document.createElement('div');
          itemsWrap.className = 'cmodal__order-items';

          if (items.length === 0) {
            itemsWrap.innerHTML = '<p class="cmodal__empty" style="padding:0.5rem 0">Sem itens registrados.</p>';
          } else {
            items.forEach(function(item) {
              var imgHtml = (item.image && item.image.length > 0)
                ? '<img src="' + item.image + '" class="cmodal__item-img" alt="' + item.name + '" crossorigin="anonymous">'
                : '<div class="cmodal__item-img-placeholder"><svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z"/></svg></div>';

              var subtotal = 'R$ ' + (item.price * item.qty).toFixed(2).replace('.', ',');
              var row = document.createElement('div');
              row.className = 'cmodal__order-item';
              row.innerHTML =
                imgHtml +
                '<div class="cmodal__item-info">' +
                  '<div class="cmodal__item-name">' + item.name + '</div>' +
                  (item.sku ? '<div class="cmodal__item-sku">' + item.sku + '</div>' : '') +
                '</div>' +
                '<div class="cmodal__item-right">' +
                  '<span class="cmodal__item-qty">x' + item.qty + '</span>' +
                  '<span class="cmodal__item-price">' + subtotal + '</span>' +
                '</div>';
              itemsWrap.appendChild(row);
            });
          }

          header.addEventListener('click', function() {
            var toggle = header.querySelector('.cmodal__order-toggle');
            var isOpen = itemsWrap.classList.toggle('is-open');
            toggle.classList.toggle('is-open', isOpen);
          });

          card.appendChild(header);
          card.appendChild(itemsWrap);
          list.appendChild(card);
        });
      }

      // Esconde spinner, mostra conteúdo
      loading.style.display = 'none';
      content.style.display = 'flex';
    })
    .catch(function() {
      loading.innerHTML = '<p class="cmodal__empty">Erro ao carregar dados. Tente novamente.</p>';
    });
  }

  function closeCustomerModal() {
    document.getElementById('customer-modal-overlay').classList.remove('is-open');
    document.body.style.overflow = '';
  }
</script>
