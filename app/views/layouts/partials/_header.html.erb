<header class="crm-header">

  <div class="crm-header__left">

    <button class="crm-header__hamburger" id="crm-hamburger" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <%= link_to painel_path, class: "crm-header__brand" do %>
      <%= image_tag 'admin/logo-store', class: 'crm-header__logo' %>
    <% end %>

  </div>

  <nav class="crm-header__nav" id="crm-nav">

    <%= link_to painel_path,
    class: "crm-header__nav-link #{'active' if current_page?(painel_path)}" do %>
      Dashboard
    <% end %>

    <%= link_to customers_path,
    class: "crm-header__nav-link #{'active' if current_page?(customers_path)}" do %>
      Clientes
    <% end %>

    <%= link_to orders_path,
    class: "crm-header__nav-link #{'active' if current_page?(orders_path)}" do %>
      Pedidos
    <% end %>

    <%= link_to products_path,
    class: "crm-header__nav-link #{'active' if current_page?(products_path)}" do %>
      Produtos
    <% end %>

    <% if current_user.admin? %>

      <%= link_to users_path,
      class: "crm-header__nav-link #{'active' if current_page?(users_path)}" do %>
        Usuários
      <% end %>

      <%= link_to profiles_path,
      class: "crm-header__nav-link #{'active' if current_page?(profiles_path)}" do %>
        Perfis
      <% end %>

      <%= link_to '/painel/sidekiq',
      class: "crm-header__nav-link" do %>
        Sidekiq
      <% end %>

    <% end %>

  </nav>

  <div class="crm-header__actions">

    <% if current_user.admin? %>
      <div class="crm-header__client-selector">
        <label for="client-selector" class="crm-header__client-label">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z" />
          </svg>
        </label>
        <select id="client-selector" class="crm-header__client-select" onchange="updateSelectedClient(this.value)">
          <option value="">Selecione um cliente</option>
          <% Client.where(active: true).order(:name).each do |client| %>
            <option value="<%= client.id %>" <%= 'selected' if session[:selected_client_id].to_i == client.id %>>
              <%= client.name %>
            </option>
          <% end %>
        </select>
      </div>
    <% end %>

    <div class="crm-header__user" id="crm-user-menu">

      <%= image_tag 'admin/usuario-200x200', class: 'crm-header__avatar' %>

      <div class="crm-header__user-info">
        <span class="crm-header__user-name"><%= current_user.name %></span>
        <span class="crm-header__user-role"><%= current_user.admin? ? 'Administrador' : 'Usuário' %></span>
      </div>

      <svg class="crm-header__chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
      </svg>

      <div class="crm-header__dropdown" id="crm-dropdown">

        <% if current_user.admin? %>

          <%= link_to users_path, class: 'crm-header__dropdown-item' do %>
            Usuários
          <% end %>

          <%= link_to profiles_path, class: 'crm-header__dropdown-item' do %>
            Perfis
          <% end %>

          <%= link_to '/painel/sidekiq', class: 'crm-header__dropdown-item', target: '_blank' do %>
            Sidekiq
          <% end %>

          <div class="crm-header__dropdown-sep"></div>

        <% end %>

        <%= link_to destroy_user_session_path,
        data: { turbo: false },
        class: 'crm-header__dropdown-item crm-header__dropdown-item--danger' do %>
          Sair
        <% end %>

      </div>

    </div>

  </div>

</header>

<div id="client-toast" class="crm-toast"></div>

<script>

  function updateSelectedClient(clientId) {
    if (!clientId) return;

    fetch('/painel/update_selected_client', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
      },
      body: JSON.stringify({ client_id: clientId })
    })
    .then(response => response.json())
    .then(data => {
      if (data.success) {
        showToast('Cliente atualizado: ' + data.client_name, 'success');
        // Recarrega a página para atualizar os dados
        setTimeout(() => window.location.reload(), 1000);
      } else {
        showToast('Erro ao atualizar cliente', 'error');
      }
    })
    .catch(() => {
      showToast('Erro ao atualizar cliente', 'error');
    });
  }

  function showToast(message, type) {
    var toast = document.getElementById('client-toast');
    toast.textContent = message;
    toast.className = 'crm-toast crm-toast--' + type + ' crm-toast--visible';
    setTimeout(function() {
      toast.classList.remove('crm-toast--visible');
    }, 3000);
  }

  (function(){

    var menu     = document.getElementById('crm-user-menu');
    var dropdown = document.getElementById('crm-dropdown');
    var chevron  = menu ? menu.querySelector('.crm-header__chevron') : null;

    if(menu && dropdown){

      menu.addEventListener('click', function(e){
        e.stopPropagation();
        var open = dropdown.style.display === 'block';
        dropdown.style.display = open ? 'none' : 'block';
        if(chevron) chevron.style.transform = open ? 'rotate(0deg)' : 'rotate(180deg)';
      });

      document.addEventListener('click', function(){
        dropdown.style.display = 'none';
        if(chevron) chevron.style.transform = 'rotate(0deg)';
      });

    }

  })();

  (function(){

    var hamburger = document.getElementById('crm-hamburger');
    var nav       = document.getElementById('crm-nav');

    if(hamburger && nav){

      hamburger.addEventListener('click', function(e){
        e.stopPropagation();
        nav.classList.toggle('open');
      });

      document.addEventListener('click', function(e){
        if(!nav.contains(e.target) && !hamburger.contains(e.target)){
          nav.classList.remove('open');
        }
      });

    }

  })();

</script>
