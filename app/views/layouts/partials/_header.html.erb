<header class="crm-header">

  <div class="crm-header__left">

    <button class="crm-header__hamburger" id="crm-hamburger" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <%= link_to painel_path, class: "crm-header__brand" do %>
      <%= image_tag 'admin/logo-store', class: 'crm-header__logo' %>
      <div class="crm-header__divider"></div>
      <%= image_tag 'admin/henrri_negativo.avif', class: 'crm-header__logo' %>
    <% end %>

  </div>

  <nav class="crm-header__nav" id="crm-nav">

    <%= link_to painel_path,
    class: "crm-header__nav-link #{'active' if current_page?(painel_path)}" do %>
      Dashboard
    <% end %>

    <%= link_to customers_path,
    class: "crm-header__nav-link #{'active' if current_page?(customers_path)}" do %>
      Clientes
    <% end %>

    <%= link_to orders_path,
    class: "crm-header__nav-link #{'active' if current_page?(orders_path)}" do %>
      Pedidos
    <% end %>

    <%= link_to products_path,
    class: "crm-header__nav-link #{'active' if current_page?(products_path)}" do %>
      Produtos
    <% end %>

    <% if current_user.admin? %>

      <%= link_to users_path,
      class: "crm-header__nav-link #{'active' if current_page?(users_path)}" do %>
        Usuários
      <% end %>

      <%= link_to profiles_path,
      class: "crm-header__nav-link #{'active' if current_page?(profiles_path)}" do %>
        Perfis
      <% end %>

      <%= link_to '/painel/sidekiq',
      class: "crm-header__nav-link" do %>
        Sidekiq
      <% end %>

    <% end %>

  </nav>

  <div class="crm-header__actions">

    <div class="crm-header__user" id="crm-user-menu">

      <%= image_tag 'admin/usuario-200x200', class: 'crm-header__avatar' %>

      <div class="crm-header__user-info">
        <span class="crm-header__user-name"><%= current_user.name %></span>
        <span class="crm-header__user-role"><%= current_user.admin? ? 'Administrador' : 'Usuário' %></span>
      </div>

      <svg class="crm-header__chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
      </svg>

      <div class="crm-header__dropdown" id="crm-dropdown">

        <% if current_user.admin? %>

          <%= link_to users_path, class: 'crm-header__dropdown-item' do %>
            Usuários
          <% end %>

          <%= link_to profiles_path, class: 'crm-header__dropdown-item' do %>
            Perfis
          <% end %>

          <%= link_to '/painel/sidekiq', class: 'crm-header__dropdown-item', target: '_blank' do %>
            Sidekiq
          <% end %>

          <div class="crm-header__dropdown-sep"></div>

        <% end %>

        <%= link_to destroy_user_session_path,
        data: { turbo: false },
        class: 'crm-header__dropdown-item crm-header__dropdown-item--danger' do %>
          Sair
        <% end %>

      </div>

    </div>

  </div>

</header>

<script>

  (function(){

    var menu     = document.getElementById('crm-user-menu');
    var dropdown = document.getElementById('crm-dropdown');
    var chevron  = menu ? menu.querySelector('.crm-header__chevron') : null;

    if(menu && dropdown){

      menu.addEventListener('click', function(e){
        e.stopPropagation();
        var open = dropdown.style.display === 'block';
        dropdown.style.display = open ? 'none' : 'block';
        if(chevron) chevron.style.transform = open ? 'rotate(0deg)' : 'rotate(180deg)';
      });

      document.addEventListener('click', function(){
        dropdown.style.display = 'none';
        if(chevron) chevron.style.transform = 'rotate(0deg)';
      });

    }

  })();

  (function(){

    var hamburger = document.getElementById('crm-hamburger');
    var nav       = document.getElementById('crm-nav');

    if(hamburger && nav){

      hamburger.addEventListener('click', function(e){
        e.stopPropagation();
        nav.classList.toggle('open');
      });

      document.addEventListener('click', function(e){
        if(!nav.contains(e.target) && !hamburger.contains(e.target)){
          nav.classList.remove('open');
        }
      });

    }

  })();

</script>
