<header class="crm-header">

  <!-- LEFT -->
  <div class="crm-header__left">

    <button class="crm-header__hamburger" id="crm-hamburger" type="button">
      ☰
    </button>

    <%= link_to painel_path, class: "crm-header__brand" do %>
      <%= image_tag 'admin/logo-store', class: 'crm-header__logo' %>
    <% end %>

  </div>

  <!-- NAV -->
  <nav class="crm-header__nav" id="crm-nav">

    <!-- DASHBOARD -->
    <%= link_to painel_path, class: "crm-header__nav-link #{'active' if current_page?(painel_path)}" do %>
      Dashboard
    <% end %>

    <!-- OPERAÇÕES -->
    <div class="crm-header__group">
      <span class="crm-header__group-label">Operações</span>

      <div class="crm-header__dropdown-nav">
        <%= link_to orders_path, class: "crm-header__dropdown-link" do %>
          Pedidos
        <% end %>

        <%= link_to customers_path, class: "crm-header__dropdown-link" do %>
          Clientes
        <% end %>

        <%= link_to products_path, class: "crm-header__dropdown-link" do %>
          Produtos
        <% end %>
      </div>
    </div>

    <!-- MARKETING -->
    <div class="crm-header__group">
      <span class="crm-header__group-label">Marketing</span>

      <div class="crm-header__dropdown-nav">
        <%= link_to painel_path, class: "crm-header__dropdown-link" do %>
          Campanhas
        <% end %>

        <%= link_to painel_path, class: "crm-header__dropdown-link" do %>
          Automações
        <% end %>
      </div>
    </div>

    <!-- ADMIN -->
    <% if current_user.admin? %>
      <div class="crm-header__group">
        <span class="crm-header__group-label">Admin</span>

        <div class="crm-header__dropdown-nav">
          <%= link_to users_path, class: "crm-header__dropdown-link" do %>
            Usuários
          <% end %>

          <%= link_to profiles_path, class: "crm-header__dropdown-link" do %>
            Perfis
          <% end %>

          <%= link_to '/painel/sidekiq', class: "crm-header__dropdown-link", target: '_blank' do %>
            Sidekiq
          <% end %>
        </div>
      </div>
    <% end %>

  </nav>

  <!-- RIGHT -->
  <div class="crm-header__actions">

    <% if current_user.admin? %>
      <select class="crm-header__client-select" onchange="updateSelectedClient(this.value)">
        <option value="">Cliente</option>
        <% Client.where(active: true).order(:name).each do |client| %>
          <option value="<%= client.id %>" <%= "selected" if session[:selected_client_id].to_i == client.id %>>
            <%= client.name %>
          </option>
        <% end %>
      </select>
    <% end %>

    <!-- USER -->
    <div class="crm-header__user" id="crm-user-menu">

      <div class="crm-header__avatar">
        <%= current_user.name.first.upcase %>
      </div>

      <div class="crm-header__dropdown" id="crm-dropdown">

        <div class="crm-header__dropdown-header">
          <strong><%= current_user.name %></strong><br>
          <span><%= current_user.admin? ? 'Administrador' : 'Usuário' %></span>
        </div>

        <div class="crm-header__dropdown-sep"></div>

        <% if current_user.admin? %>
          <%= link_to users_path, class: 'crm-header__dropdown-item' do %>
            Usuários
          <% end %>

          <%= link_to profiles_path, class: 'crm-header__dropdown-item' do %>
            Perfis
          <% end %>

          <%= link_to '/painel/sidekiq', class: 'crm-header__dropdown-item', target: '_blank' do %>
            Sidekiq
          <% end %>

          <div class="crm-header__dropdown-sep"></div>
        <% end %>

        <%= link_to destroy_user_session_path,
          data: { turbo: false },
          class: 'crm-header__dropdown-item crm-header__dropdown-item--danger' do %>
          Sair
        <% end %>

      </div>

    </div>

  </div>

</header>

<style>

/* RESET */
* { box-sizing: border-box; margin: 0; padding: 0; }

/* HEADER */
.crm-header {
  height: 64px;
  background: #fff;
  border-bottom: 1px solid #eee;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
}

/* LEFT */
.crm-header__left {
  display: flex;
  align-items: center;
  gap: 15px;
}

.crm-header__logo {
  height: 70px;
}

/* SEARCH */
.crm-header__search input {
  height: 36px;
  border-radius: 8px;
  border: 1px solid #ddd;
  padding: 0 12px;
  font-size: 14px;
}

/* NAV */
.crm-header__nav {
  display: flex;
  align-items: center;
  gap: 25px;
}

.crm-header__nav-link {
  color: #555;
  text-decoration: none;
  font-weight: 500;
}

.crm-header__nav-link.active {
  color: #3b4adf;
}

/* GROUP */
.crm-header__group {
  position: relative;
}

.crm-header__group-label {
  cursor: pointer;
  font-size: 14px;
  color: #555;
}

.crm-header__dropdown-nav {
  position: absolute;
  top: 30px;
  left: 0;
  background: #fff;
  border: 1px solid #eee;
  border-radius: 10px;
  display: none;
  min-width: 160px;
}

.crm-header__group:hover .crm-header__dropdown-nav {
  display: block;
}

.crm-header__dropdown-link {
  display: block;
  padding: 10px;
  color: #333;
  text-decoration: none;
}

.crm-header__dropdown-link:hover {
  background: #f5f7ff;
}

/* RIGHT */
.crm-header__actions {
  display: flex;
  align-items: center;
  gap: 15px;
}

/* USER */
.crm-header__user {
  position: relative;
  cursor: pointer;
}

.crm-header__avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #3b4adf;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

/* DROPDOWN */
.crm-header__dropdown {
  position: absolute;
  right: 0;
  top: 50px;
  width: 200px;
  background: #fff;
  border: 1px solid #eee;
  border-radius: 10px;
  display: none;
}

.crm-header__dropdown-header {
  padding: 10px;
  font-size: 13px;
}

.crm-header__dropdown-sep {
  height: 1px;
  background: #eee;
}

.crm-header__dropdown-item {
  display: block;
  padding: 10px;
  text-decoration: none;
  color: #333;
}

.crm-header__dropdown-item:hover {
  background: #f5f7ff;
}

.crm-header__dropdown-item--danger {
  color: #e74c3c;
}

/* HAMBURGER */
.crm-header__hamburger {
  display: none;
  background: none;
  border: none;
  font-size: 20px;
}

/* MOBILE */
@media (max-width: 768px) {

  .crm-header__nav {
    display: none;
    position: absolute;
    top: 64px;
    left: 0;
    width: 100%;
    background: white;
    flex-direction: column;
    padding: 1rem;
  }

  .crm-header__nav.open {
    display: flex;
  }

  .crm-header__hamburger {
    display: block;
  }

}

</style>

<script>

/* CLIENT */
function updateSelectedClient(clientId) {
  if (!clientId) return;

  fetch('/painel/update_selected_client', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
    },
    body: JSON.stringify({ client_id: clientId })
  })
  .then(() => location.reload());
}

/* USER DROPDOWN */
(function(){
  const menu = document.getElementById('crm-user-menu');
  const dropdown = document.getElementById('crm-dropdown');

  if(menu){
    menu.addEventListener('click', (e)=>{
      e.stopPropagation();
      dropdown.style.display =
        dropdown.style.display === 'block' ? 'none' : 'block';
    });

    document.addEventListener('click', ()=>{
      dropdown.style.display = 'none';
    });
  }
})();

/* HAMBURGER */
(function(){
  const btn = document.getElementById('crm-hamburger');
  const nav = document.getElementById('crm-nav');

  if(btn && nav){
    btn.addEventListener('click', ()=>{
      nav.classList.toggle('open');
    });
  }
})();

</script>