<header class="crm-header">

  <!-- LEFT -->
  <div class="crm-header__left">

    <button class="crm-header__hamburger" id="crm-hamburger" type="button" aria-label="Abrir menu" aria-expanded="false">
      <span class="crm-hamburger__bar"></span>
      <span class="crm-hamburger__bar"></span>
      <span class="crm-hamburger__bar"></span>
    </button>

    <%= link_to painel_path, class: "crm-header__brand" do %>
      <%= image_tag 'admin/logo-novo.png', class: 'crm-header__logo' %>
    <% end %>

  </div>

  <!-- NAV -->
  <nav class="crm-header__nav" id="crm-nav">

    <% if current_user.profile_id == Profile::AFFILIATE %>
      <!-- AFILIADO: apenas seus eventos -->
      <%= link_to events_path(utm_code: current_user.utm_code), class: "crm-header__nav-link #{'active' if request.path.start_with?(events_path)}" do %>
        <i class="fa-solid fa-chart-line crm-fa"></i>
        Meus Eventos
      <% end %>
    <% else %>
      <!-- DASHBOARD -->
      <%= link_to painel_path, class: "crm-header__nav-link #{'active' if current_page?(painel_path)}" do %>
        <i class="fa-solid fa-chart-line crm-fa"></i>
        Dashboard
      <% end %>

      <!-- OPERAÇÕES -->
      <div class="crm-header__group" data-group>
        <span class="crm-header__group-label" data-group-toggle>
          <i class="fa-solid fa-gear crm-fa"></i>
          Operações
          <i class="fa-solid fa-chevron-down crm-group-chevron"></i>
        </span>

        <div class="crm-header__dropdown-nav">
          <%= link_to orders_path, class: "crm-header__dropdown-link #{'active' if current_page?(orders_path)}" do %>
            <i class="fa-solid fa-box crm-fa"></i>
            Pedidos
          <% end %>

          <%= link_to customers_path, class: "crm-header__dropdown-link #{'active' if current_page?(customers_path)}" do %>
            <i class="fa-solid fa-users crm-fa"></i>
            Clientes
          <% end %>

          <%= link_to products_path, class: "crm-header__dropdown-link #{'active' if current_page?(products_path)}" do %>
            <i class="fa-solid fa-bag-shopping crm-fa"></i>
            Produtos
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- MARKETING (oculto para afiliados) -->
    <% unless current_user.profile_id == Profile::AFFILIATE %>
      <div class="crm-header__group" data-group>
        <span class="crm-header__group-label" data-group-toggle>
          <i class="fa-solid fa-bullhorn crm-fa"></i>
          Marketing
          <i class="fa-solid fa-chevron-down crm-group-chevron"></i>
        </span>

        <div class="crm-header__dropdown-nav">
          <%= link_to campaigns_path, class: "crm-header__dropdown-link #{'active' if request.path.start_with?(campaigns_path)}" do %>
            <i class="fa-solid fa-bullseye crm-fa"></i>
            Campanhas
          <% end %>

          <%= link_to affiliates_path, class: "crm-header__dropdown-link #{'active' if request.path.start_with?(affiliates_path)}" do %>
            <i class="fa-solid fa-user-group crm-fa"></i>
            Afiliados
          <% end %>

          <%= link_to painel_path, class: "crm-header__dropdown-link" do %>
            <i class="fa-solid fa-robot crm-fa"></i>
            Automações
          <% end %>
        </div>
      </div>
    <% end %>

    <!-- ADMIN -->
    <% if current_user.admin? %>
      <div class="crm-header__group" data-group>
        <span class="crm-header__group-label" data-group-toggle>
          <i class="fa-solid fa-shield-halved crm-fa"></i>
          Admin
          <i class="fa-solid fa-chevron-down crm-group-chevron"></i>
        </span>

        <div class="crm-header__dropdown-nav">
          <%= link_to users_path, class: "crm-header__dropdown-link #{'active' if request.path.start_with?(users_path)}" do %>
            <i class="fa-solid fa-user crm-fa"></i>
            Usuários
          <% end %>

          <%= link_to clients_path, class: "crm-header__dropdown-link #{'active' if request.path.start_with?(clients_path)}" do %>
            <i class="fa-solid fa-building crm-fa"></i>
            Clientes
          <% end %>

          <%= link_to profiles_path, class: "crm-header__dropdown-link #{'active' if request.path.start_with?(profiles_path)}" do %>
            <i class="fa-solid fa-id-badge crm-fa"></i>
            Perfis
          <% end %>

          <%= link_to '/painel/sidekiq', class: "crm-header__dropdown-link", target: '_blank' do %>
            <i class="fa-solid fa-bolt crm-fa"></i>
            Sidekiq
          <% end %>
        </div>
      </div>
    <% end %>

  </nav>

  <!-- RIGHT -->
  <div class="crm-header__actions">

    <% if current_user.admin? %>
      <select class="crm-header__client-select" onchange="updateSelectedClient(this.value)">
        <option value="">Cliente</option>
        <% Client.where(active: true).order(:name).each do |client| %>
          <option value="<%= client.id %>" <%= "selected" if session[:selected_client_id].to_i == client.id %>>
            <%= client.name %>
          </option>
        <% end %>
      </select>
    <% end %>

    <!-- USER -->
    <div class="crm-header__user" id="crm-user-menu">

      <div class="crm-header__avatar">
        <%= current_user.name.first.upcase %>
      </div>

      <i class="fa-solid fa-chevron-down crm-user-chevron"></i>

      <div class="crm-header__dropdown" id="crm-dropdown">

        <div class="crm-header__dropdown-header">
          <strong><%= current_user.name %></strong><br>
          <span><%= current_user.admin? ? 'Administrador' : 'Usuário' %></span>
        </div>

        <div class="crm-header__dropdown-sep"></div>

        <% if current_user.admin? %>
          <%= link_to users_path, class: 'crm-header__dropdown-item' do %>
            <i class="fa-solid fa-user crm-fa"></i>
            Usuários
          <% end %>

          <%= link_to clients_path, class: 'crm-header__dropdown-item' do %>
            <i class="fa-solid fa-building crm-fa"></i>
            Clientes
          <% end %>

          <%= link_to profiles_path, class: 'crm-header__dropdown-item' do %>
            <i class="fa-solid fa-id-badge crm-fa"></i>
            Perfis
          <% end %>

          <%= link_to '/painel/sidekiq', class: 'crm-header__dropdown-item', target: '_blank' do %>
            <i class="fa-solid fa-bolt crm-fa"></i>
            Sidekiq
          <% end %>

          <div class="crm-header__dropdown-sep"></div>
        <% end %>

        <%= link_to destroy_user_session_path,
          data: { turbo: false },
          class: 'crm-header__dropdown-item crm-header__dropdown-item--danger' do %>
          <i class="fa-solid fa-right-from-bracket crm-fa"></i>
          Sair
        <% end %>

      </div>

    </div>

  </div>

</header>

<!-- MOBILE OVERLAY -->
<div class="crm-nav-overlay" id="crm-nav-overlay"></div>

<style>

/* RESET */
* { box-sizing: border-box; margin: 0; padding: 0; }

.crm-fa {
  margin-right: 6px;
  color: #666;
  font-size: 13px;
}

/* HEADER */
.crm-header {
  height: 64px;
  background: #fff;
  border-bottom: 1px solid #eee;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 20px;
  position: sticky;
  top: 0;
  z-index: 200;
  transition: background 0.25s ease, backdrop-filter 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
}

.crm-header.scrolled {
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border-bottom-color: rgba(230, 232, 245, 0.6);
  box-shadow: 0 2px 16px rgba(30, 40, 100, 0.06);
}

/* LEFT */
.crm-header__left {
  display: flex;
  align-items: center;
  gap: 15px;
}

.crm-header__logo {
  width: 140px;
}

/* NAV */
.crm-header__nav {
  display: flex;
  align-items: center;
  gap: 4px;
}

.crm-header__nav-link {
  color: #555;
  text-decoration: none;
  font-weight: 500;
  font-size: 14px;
  padding: 6px 12px;
  border-radius: 8px;
  transition: background 0.15s, color 0.15s;
}

.crm-header__nav-link:hover {
  background: #f5f7ff;
  color: #3b4adf;
}

.crm-header__nav-link.active {
  color: #3b4adf;
  background: #eef0fd;
}

/* GROUP */
.crm-header__group {
  position: relative;
}

.crm-header__group::after {
  content: '';
  position: absolute;
  top: calc(100% - 4px);
  left: 0;
  right: 0;
  height: 16px;
  pointer-events: auto;
  z-index: 301;
}

.crm-header__group-label {
  cursor: pointer;
  font-size: 14px;
  font-weight: 500;
  color: #555;
  display: flex;
  align-items: center;
  gap: 2px;
  padding: 6px 12px;
  border-radius: 8px;
  transition: background 0.15s, color 0.15s;
  user-select: none;
}

.crm-header__group-label:hover {
  background: #f5f7ff;
  color: #3b4adf;
}

.crm-group-chevron {
  font-size: 11px;
  color: #888;
  margin-left: 4px;
  transition: transform 0.2s ease;
}

.crm-header__group:hover .crm-group-chevron {
  transform: rotate(180deg);
}

/* DROPDOWN NAV */
.crm-header__dropdown-nav {
  position: absolute;
  top: calc(100% + 6px);
  left: 0;
  background: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 12px;
  display: none;
  min-width: 180px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.08);
  padding: 6px;
  z-index: 300;
  pointer-events: auto;
}

.crm-header__group:hover .crm-header__dropdown-nav,
.crm-header__dropdown-nav:hover {
  display: block;
  animation: fadeInDown 0.15s ease;
}

@keyframes fadeInDown {
  from { opacity: 0; transform: translateY(-6px); }
  to   { opacity: 1; transform: translateY(0); }
}

.crm-header__dropdown-link {
  display: flex;
  align-items: center;
  padding: 9px 12px;
  color: #333;
  text-decoration: none;
  font-size: 14px;
  border-radius: 8px;
  transition: background 0.12s, color 0.12s;
}

.crm-header__dropdown-link:hover,
.crm-header__dropdown-link.active {
  background: #f5f7ff;
  color: #3b4adf;
}

.crm-header__dropdown-link:hover .crm-fa,
.crm-header__dropdown-link.active .crm-fa {
  color: #3b4adf;
}

/* RIGHT */
.crm-header__actions {
  display: flex;
  align-items: center;
  gap: 12px;
}

/* CLIENT SELECT */
.crm-header__client-select {
  height: 36px;
  border-radius: 8px;
  border: 1px solid #ddd;
  padding: 0 10px;
  font-size: 13px;
  color: #444;
  background: #fff;
  cursor: pointer;
  outline: none;
  transition: border-color 0.15s;
}

.crm-header__client-select:focus {
  border-color: #3b4adf;
}

/* USER */
.crm-header__user {
  position: relative;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 8px 4px 4px;
  border-radius: 40px;
  transition: background 0.15s;
}

.crm-header__user:hover {
  background: #f5f5f5;
}

.crm-header__avatar {
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: #3b4adf;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  font-size: 14px;
  flex-shrink: 0;
}

.crm-user-chevron {
  font-size: 11px;
  color: #888;
  transition: transform 0.2s ease;
}

.crm-user-chevron.open {
  transform: rotate(180deg);
}

/* USER DROPDOWN */
.crm-header__dropdown {
  position: absolute;
  right: 0;
  top: calc(100% + 8px);
  width: 210px;
  background: #fff;
  border: 1px solid #e8e8e8;
  border-radius: 12px;
  box-shadow: 0 8px 24px rgba(0,0,0,0.1);
  display: none;
  padding: 6px;
  z-index: 300;
  animation: fadeInDown 0.15s ease;
}

.crm-header__dropdown.open {
  display: block;
}

.crm-header__dropdown-header {
  padding: 10px 12px 12px;
  font-size: 13px;
  color: #555;
}

.crm-header__dropdown-header strong {
  font-size: 14px;
  color: #222;
  display: block;
  margin-bottom: 2px;
}

.crm-header__dropdown-sep {
  height: 1px;
  background: #f0f0f0;
  margin: 4px 0;
}

.crm-header__dropdown-item {
  display: flex;
  align-items: center;
  padding: 9px 12px;
  text-decoration: none;
  color: #333;
  font-size: 14px;
  border-radius: 8px;
  transition: background 0.12s, color 0.12s;
}

.crm-header__dropdown-item:hover {
  background: #f5f7ff;
  color: #3b4adf;
}

.crm-header__dropdown-item:hover .crm-fa {
  color: #3b4adf;
}

.crm-header__dropdown-item--danger {
  color: #e74c3c !important;
}

.crm-header__dropdown-item--danger:hover {
  background: #fff5f5 !important;
  color: #c0392b !important;
}

.crm-header__dropdown-item--danger .crm-fa {
  color: #e74c3c !important;
}

/* =====================
   HAMBURGER
   ===================== */
.crm-header__hamburger {
  display: none;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  gap: 5px;
  width: 38px;
  height: 38px;
  background: none;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  padding: 0;
  transition: background 0.15s;
}

.crm-header__hamburger:hover {
  background: #f5f5f5;
}

.crm-hamburger__bar {
  display: block;
  width: 20px;
  height: 2px;
  background: #444;
  border-radius: 2px;
  transition: transform 0.25s ease, opacity 0.2s ease, width 0.2s ease;
  transform-origin: center;
}

.crm-header__hamburger.open .crm-hamburger__bar:nth-child(1) {
  transform: translateY(7px) rotate(45deg);
}
.crm-header__hamburger.open .crm-hamburger__bar:nth-child(2) {
  opacity: 0;
  width: 0;
}
.crm-header__hamburger.open .crm-hamburger__bar:nth-child(3) {
  transform: translateY(-7px) rotate(-45deg);
}

/* =====================
   MOBILE OVERLAY
   ===================== */
.crm-nav-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.25);
  z-index: 150;
}

.crm-nav-overlay.open {
  display: block;
}

/* =====================
   MOBILE NAV
   ===================== */
@media (max-width: 768px) {

  .crm-header__hamburger {
    display: flex;
  }

  .crm-header__nav {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 280px;
    height: 100dvh;
    background: #fff;
    flex-direction: column;
    align-items: stretch;
    gap: 2px;
    padding: 80px 12px 24px;
    overflow-y: auto;
    z-index: 180;
    box-shadow: 4px 0 20px rgba(0,0,0,0.1);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
  }

  /* overlay cobre a tela toda por baixo do drawer */
  .crm-nav-overlay {
    z-index: 160;
  }

  .crm-header__nav.open {
    display: flex;
    transform: translateX(0);
  }

  .crm-header__nav-link {
    padding: 10px 14px;
    font-size: 15px;
    border-radius: 10px;
  }

  .crm-header__group {
    width: 100%;
  }

  .crm-header__group-label {
    width: 100%;
    padding: 10px 14px;
    font-size: 15px;
    border-radius: 10px;
    justify-content: space-between;
  }

  .crm-group-chevron {
    margin-left: auto;
  }

  .crm-header__dropdown-nav {
    position: static;
    box-shadow: none;
    border: none;
    border-radius: 0;
    background: #f9f9f9;
    border-radius: 10px;
    margin-top: 4px;
    margin-left: 8px;
    display: none;
    padding: 4px;
    animation: none;
  }

  .crm-header__group.mobile-open .crm-header__dropdown-nav {
    display: block;
  }

  .crm-header__group.mobile-open .crm-group-chevron {
    transform: rotate(180deg);
  }

  .crm-header__group:hover .crm-header__dropdown-nav {
    display: none;
  }

  .crm-header__group.mobile-open .crm-header__dropdown-nav {
    display: block !important;
  }

  .crm-header__group:hover .crm-group-chevron {
    transform: none;
  }

  .crm-header__group.mobile-open .crm-group-chevron {
    transform: rotate(180deg) !important;
  }

  .crm-header__client-select {
    display: none;
  }

}

</style>

<script>

/* CLIENT */
function updateSelectedClient(clientId) {
  if (!clientId) return;

  fetch('/painel/update_selected_client', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
    },
    body: JSON.stringify({ client_id: clientId })
  })
  .then(() => location.reload());
}

(function () {

  /* USER DROPDOWN */
  const menu     = document.getElementById('crm-user-menu');
  const dropdown = document.getElementById('crm-dropdown');
  const chevron  = menu ? menu.querySelector('.crm-user-chevron') : null;

  function closeUserDropdown() {
    if (!dropdown) return;
    dropdown.classList.remove('open');
    if (chevron) chevron.classList.remove('open');
  }

  function openUserDropdown() {
    if (!dropdown) return;
    dropdown.classList.add('open');
    if (chevron) chevron.classList.add('open');
  }

  if (menu) {
    menu.addEventListener('click', function (e) {
      e.stopPropagation();
      const isOpen = dropdown.classList.contains('open');
      isOpen ? closeUserDropdown() : openUserDropdown();
    });

    document.addEventListener('click', function () {
      closeUserDropdown();
    });

    dropdown.addEventListener('click', function (e) {
      e.stopPropagation();
    });
  }

  /* HAMBURGER */
  const hamburger = document.getElementById('crm-hamburger');
  const nav       = document.getElementById('crm-nav');
  const overlay   = document.getElementById('crm-nav-overlay');

  function openNav() {
    nav.classList.add('open');
    hamburger.classList.add('open');
    overlay.classList.add('open');
    hamburger.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
  }

  function closeNav() {
    nav.classList.remove('open');
    hamburger.classList.remove('open');
    overlay.classList.remove('open');
    hamburger.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  }

  if (hamburger && nav) {
    hamburger.addEventListener('click', function () {
      nav.classList.contains('open') ? closeNav() : openNav();
    });
  }

  if (overlay) {
    overlay.addEventListener('click', closeNav);
  }

  const isMobile = () => window.innerWidth <= 768;

  document.querySelectorAll('[data-group-toggle]').forEach(function (toggle) {
    toggle.addEventListener('click', function (e) {
      if (!isMobile()) return;
      e.stopPropagation();
      const group = toggle.closest('[data-group]');
      if (!group) return;
      group.classList.toggle('mobile-open');
    });
  });

  /* STICKY BLUR */
  const header = document.querySelector('.crm-header');
  if (header) {
    const onScroll = function () {
      if (window.scrollY > 10) {
        header.classList.add('scrolled');
      } else {
        header.classList.remove('scrolled');
      }
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
  }

})();

</script>
