<header class="crm-header">

  <%# Logo e Título %>
  <div class="crm-header__brand">
    <%= image_tag 'admin/logo-store', class: 'crm-header__logo', alt: 'Logo' %>
    <div class="crm-header__divider"></div>
    <h1 class="crm-header__title"><%= yield :title %></h1>
  </div>

  <%# Navegação %>
  <nav class="crm-header__nav">
    <%= link_to root_path, class: "crm-header__nav-link" do %>
      <svg class="crm-header__nav-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955a1.5 1.5 0 012.092 0L21.75 12M4.5 9.75v9.75A.75.75 0 005.25 20.25h4.5a.75.75 0 00.75-.75v-4.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75v4.5a.75.75 0 00.75.75h4.5a.75.75 0 00.75-.75V9.75" />
      </svg>
      Home
    <% end %>

    <%= link_to customers_path, class: "crm-header__nav-link" do %>
      <svg class="crm-header__nav-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z" />
      </svg>
      Clientes
    <% end %>

    <%= link_to orders_path, class: "crm-header__nav-link" do %>
      <svg class="crm-header__nav-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
      </svg>
      Pedidos
    <% end %>

    <%= link_to products_path, class: "crm-header__nav-link" do %>
      <svg class="crm-header__nav-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
      </svg>
      Produtos
    <% end %>

    <%= link_to '#', class: "crm-header__nav-link" do %>
      <svg class="crm-header__nav-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
      </svg>
      Relatorios
    <% end %>

    <%= link_to '#', class: "crm-header__nav-link" do %>
      <svg class="crm-header__nav-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      Campanhas
    <% end %>
    <%= link_to '#', class: "crm-header__nav-link" do %>
      <svg class="crm-header__nav-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
      Configuracoes
    <% end %>
  </nav>

  <%# Busca + Usuário %>
  <div class="crm-header__actions">

    <div class="crm-header__user" id="crm-user-menu">
      <%= image_tag 'admin/usuario-200x200', class: 'crm-header__avatar', alt: 'Foto do usuário' %>
      <div class="crm-header__user-info">
        <span class="crm-header__user-name"><%= current_user.name %></span>
        <span class="crm-header__user-role">Administrador</span>
      </div>
      <svg class="crm-header__chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
      </svg>

      <div class="crm-header__dropdown" id="crm-dropdown">
        <%= link_to '#', class: 'crm-header__dropdown-item' do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
          </svg>
          Perfil
        <% end %>
        <%= link_to '#', class: 'crm-header__dropdown-item' do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Configuracoes
        <% end %>
        <%= link_to destroy_user_session_path(current_user), data: { turbo: :false }, class: 'crm-header__dropdown-item crm-header__dropdown-item--danger' do %>
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15m3 0l3-3m0 0l-3-3m3 3H9" />
          </svg>
          Sair
        <% end %>
      </div>
    </div>

  </div>
</header>

<style>
  .crm-header {
    background: #ffffff;
    border-bottom: 1px solid #e4e7f0;
    padding: 0 2rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
  }

  .crm-header__brand {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex: 0 0 auto;
  }

  .crm-header__logo {
    width: 100px;
    height: 100px;
    object-fit: contain;
  }

  .crm-header__divider {
    width: 1px;
    height: 28px;
    background: #e4e7f0;
  }

  .crm-header__title {
    margin: 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: #1e2235;
    white-space: nowrap;
  }

  .crm-header__nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
  }

  .crm-header__nav-link {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 1rem;
    border-radius: 8px;
    color: #5a6380;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .crm-header__nav-link:hover {
    background: #f0f2fb;
    color: #3b4adf;
  }

  .crm-header__nav-link.active {
    background: #eef0fd;
    color: #3b4adf;
  }

  .crm-header__nav-icon {
    width: 16px;
    height: 16px;
    opacity: 0.75;
  }

  .crm-header__actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex: 0 0 auto;
  }

  .crm-header__search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: #f4f5fb;
    border: 1px solid #e4e7f0;
    border-radius: 8px;
    padding: 0.4rem 0.9rem;
    transition: border-color 0.15s ease;
  }

  .crm-header__search:focus-within {
    border-color: #3b4adf;
    background: #fff;
  }

  .crm-header__search svg {
    color: #9097b5;
    flex-shrink: 0;
  }

  .crm-header__search input {
    border: none;
    background: transparent;
    outline: none;
    font-size: 0.875rem;
    color: #1e2235;
    width: 130px;
  }

  .crm-header__search input::placeholder {
    color: #9097b5;
  }

  .crm-header__user-sep {
    width: 1px;
    height: 28px;
    background: #e4e7f0;
  }

  .crm-header__user {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    position: relative;
    cursor: pointer;
  }

  .crm-header__avatar {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #e4e7f0;
  }

  .crm-header__user-info {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .crm-header__user-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1e2235;
    white-space: nowrap;
  }

  .crm-header__user-role {
    font-size: 0.75rem;
    color: #9097b5;
  }

  .crm-header__chevron {
    color: #9097b5;
    transition: transform 0.2s ease;
  }

  .crm-header__dropdown {
    display: none;
    position: absolute;
    top: calc(100% + 12px);
    right: 0;
    background: #ffffff;
    border: 1px solid #e4e7f0;
    border-radius: 10px;
    box-shadow: 0 6px 20px rgba(0,0,0,0.09);
    min-width: 170px;
    z-index: 1000;
    overflow: hidden;
  }

  .crm-header__dropdown-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.7rem 1rem;
    color: #1e2235;
    text-decoration: none;
    font-size: 0.875rem;
    transition: background 0.15s ease;
    border-bottom: 1px solid #f0f2f8;
  }

  .crm-header__dropdown-item:last-child {
    border-bottom: none;
  }

  .crm-header__dropdown-item:hover {
    background: #f4f5fb;
  }

  .crm-header__dropdown-item--danger {
    color: #d94f4f;
  }

  .crm-header__dropdown-item--danger:hover {
    background: #fff5f5;
  }
</style>

<script>
  (function() {
    var menu = document.getElementById('crm-user-menu');
    var dropdown = document.getElementById('crm-dropdown');

    if (menu && dropdown) {
      menu.addEventListener('click', function(e) {
        e.stopPropagation();
        var isOpen = dropdown.style.display === 'block';
        dropdown.style.display = isOpen ? 'none' : 'block';
        menu.querySelector('.crm-header__chevron').style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
      });

      document.addEventListener('click', function() {
        dropdown.style.display = 'none';
        menu.querySelector('.crm-header__chevron').style.transform = 'rotate(0deg)';
      });
    }
  })();
</script>
