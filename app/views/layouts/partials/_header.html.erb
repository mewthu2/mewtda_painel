<header class="crm-header">

  <div class="crm-header__left">

    <button class="crm-header__hamburger" id="crm-hamburger" type="button">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>

    <%= link_to painel_path, class: "crm-header__brand" do %>
      <%= image_tag 'admin/logo-store', class: 'crm-header__logo' %>
    <% end %>

  </div>

  <nav class="crm-header__nav" id="crm-nav">

    <%= link_to painel_path, class: "crm-header__nav-link #{'active' if current_page?(painel_path)}" do %>
      Dashboard
    <% end %>

    <%= link_to customers_path, class: "crm-header__nav-link #{'active' if current_page?(customers_path)}" do %>
      Clientes
    <% end %>

    <%= link_to orders_path, class: "crm-header__nav-link #{'active' if current_page?(orders_path)}" do %>
      Pedidos
    <% end %>

    <%= link_to products_path, class: "crm-header__nav-link #{'active' if current_page?(products_path)}" do %>
      Produtos
    <% end %>

    <% if current_user.admin? %>
      <%= link_to users_path, class: "crm-header__nav-link #{'active' if current_page?(users_path)}" do %>
        Usuários
      <% end %>

      <%= link_to profiles_path, class: "crm-header__nav-link #{'active' if current_page?(profiles_path)}" do %>
        Perfis
      <% end %>

      <%= link_to '/painel/sidekiq', class: "crm-header__nav-link" do %>
        Sidekiq
      <% end %>
    <% end %>

  </nav>

  <div class="crm-header__actions">

    <% if current_user.admin? %>
      <div class="crm-header__client-selector">
        <select id="client-selector" class="crm-header__client-select" onchange="updateSelectedClient(this.value)">
          <option value="">Cliente</option>
          <% Client.where(active: true).order(:name).each do |client| %>
            <option value="<%= client.id %>" <%= 'selected' if session[:selected_client_id].to_i == client.id %>>
              <%= client.name %>
            </option>
          <% end %>
        </select>
      </div>
    <% end %>

    <div class="crm-header__user" id="crm-user-menu">

      <%= image_tag 'admin/usuario-200x200', class: 'crm-header__avatar' %>

      <div class="crm-header__user-info">
        <span class="crm-header__user-name-full"><%= current_user.name %></span>
        <span class="crm-header__user-initial">
          <%= current_user.name.first.upcase %>
        </span>
        <span class="crm-header__user-role"><%= current_user.admin? ? 'Administrador' : 'Usuário' %></span>
      </div>

      <svg class="crm-header__chevron" xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
      </svg>

      <div class="crm-header__dropdown" id="crm-dropdown">

        <% if current_user.admin? %>
          <%= link_to users_path, class: 'crm-header__dropdown-item' do %>
            Usuários
          <% end %>

          <%= link_to profiles_path, class: 'crm-header__dropdown-item' do %>
            Perfis
          <% end %>

          <%= link_to '/painel/sidekiq', class: 'crm-header__dropdown-item', target: '_blank' do %>
            Sidekiq
          <% end %>

          <div class="crm-header__dropdown-sep"></div>
        <% end %>

        <%= link_to destroy_user_session_path,
        data: { turbo: false },
        class: 'crm-header__dropdown-item crm-header__dropdown-item--danger' do %>
          Sair
        <% end %>

      </div>

    </div>

  </div>

</header>

<div id="client-toast" class="crm-toast"></div>

<style>

/* RESET */
* { box-sizing: border-box; margin: 0; padding: 0; }

/* HEADER */
.crm-header {
  height: 64px;
  background: #fff;
  border-bottom: 1px solid #e6e9f2;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 1.2rem;
}

/* LEFT */
.crm-header__left {
  display: flex;
  align-items: center;
  gap: 0.8rem;
}

.crm-header__logo {
  height: 32px;
}

/* NAV */
.crm-header__nav {
  display: flex;
  gap: 1.2rem;
}

.crm-header__nav-link {
  text-decoration: none;
  color: #5b648a;
  font-size: 0.9rem;
  font-weight: 500;
}

.crm-header__nav-link.active {
  color: #3b4adf;
}

/* ACTIONS */
.crm-header__actions {
  display: flex;
  align-items: center;
  gap: 1rem;
}

/* USER */
.crm-header__user {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  cursor: pointer;
  position: relative;
}

.crm-header__avatar {
  width: 36px;
  height: 36px;
  border-radius: 50%;
}

.crm-header__user-info {
  display: flex;
  flex-direction: column;
}

.crm-header__user-name-full {
  font-size: 0.85rem;
  font-weight: 600;
}

.crm-header__user-role {
  font-size: 0.7rem;
  color: #8c93b3;
}

/* INITIAL */
.crm-header__user-initial {
  display: none;
  width: 32px;
  height: 32px;
  border-radius: 50%;
  background: #3b4adf;
  color: #fff;
  font-weight: 700;
  font-size: 0.9rem;
  align-items: center;
  justify-content: center;
}

/* DROPDOWN */
.crm-header__dropdown {
  position: absolute;
  top: 50px;
  right: 0;
  background: #fff;
  border: 1px solid #e6e9f2;
  border-radius: 10px;
  display: none;
  min-width: 180px;
}

.crm-header__dropdown-item {
  display: block;
  padding: 0.7rem 1rem;
  text-decoration: none;
  color: #333;
}

.crm-header__dropdown-item:hover {
  background: #f5f7ff;
}

.crm-header__dropdown-item--danger {
  color: #e74c3c;
}

/* HAMBURGER */
.crm-header__hamburger {
  display: none;
  background: none;
  border: none;
}

/* MOBILE */
@media (max-width: 768px) {

  .crm-header__nav {
    position: absolute;
    top: 64px;
    left: 0;
    width: 100%;
    background: white;
    flex-direction: column;
    padding: 1rem;
    display: none;
  }

  .crm-header__nav.open {
    display: flex;
  }

  .crm-header__hamburger {
    display: block;
  }

  .crm-header__user-name-full,
  .crm-header__user-role {
    display: none;
  }

  .crm-header__user-initial {
    display: flex;
  }

  .crm-header__avatar {
    width: 32px;
    height: 32px;
  }

}

</style>

<script>

function updateSelectedClient(clientId) {
  if (!clientId) return;

  fetch('/painel/update_selected_client', {
    method: 'POST',
    headers: {
      'Content-Type': 'application/json',
      'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
    },
    body: JSON.stringify({ client_id: clientId })
  })
  .then(res => res.json())
  .then(() => location.reload());
}

/* DROPDOWN */
(function(){
  var menu = document.getElementById('crm-user-menu');
  var dropdown = document.getElementById('crm-dropdown');

  if(menu && dropdown){
    menu.addEventListener('click', function(e){
      e.stopPropagation();
      dropdown.style.display = dropdown.style.display === 'block' ? 'none' : 'block';
    });

    document.addEventListener('click', function(){
      dropdown.style.display = 'none';
    });
  }
})();

/* HAMBURGER */
(function(){
  var btn = document.getElementById('crm-hamburger');
  var nav = document.getElementById('crm-nav');

  if(btn && nav){
    btn.addEventListener('click', function(e){
      e.stopPropagation();
      nav.classList.toggle('open');
    });

    document.addEventListener('click', function(e){
      if(!nav.contains(e.target) && !btn.contains(e.target)){
        nav.classList.remove('open');
      }
    });
  }
})();

</script>