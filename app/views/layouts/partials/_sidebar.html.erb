<aside class="left-menu bg-dark border-end shadow-lg" style="background: linear-gradient(180deg, #1a1d29 0%, #252837 100%) !important;">
  <div class="aside-inner">
    <div class="flex-shrink-0 p-3">
      <!-- Navigation Menu -->
      <ul class="nav nav-pills flex-column mb-auto">
        <!-- Added Home link -->
        <%= link_to root_path, class: 'btn btn-outline-info text-info mb-2 sidebar-btn d-flex align-items-center gap-2', 
            style: 'transition: all 0.3s ease;' do %>
          <i class="fa fa-home"></i>
          <span class="name-button">Home</span>
        <% end %>

        <!-- Improved Leads button styling -->
        <%= link_to leads_path, class: 'btn btn-primary text-white mb-2 sidebar-btn d-flex align-items-center gap-2 position-relative', 
            style: 'background: linear-gradient(135deg, #17a2b8 0%, #138496 100%); border: none; transition: all 0.3s ease;' do %>
          <i class="fa-regular fa-envelope"></i>
          <span class="name-button">Leads</span>
          <span class="badge bg-light text-dark position-absolute end-0 me-2" style="font-size: 0.65rem;">NEW</span>
        <% end %>

        <!-- Additional Menu Items (examples) -->
        <li class="nav-item mb-2">
          <a href="#" class="btn btn-outline-secondary text-light sidebar-btn d-flex align-items-center gap-2" 
             style="transition: all 0.3s ease;">
            <i class="fa fa-chart-line"></i>
            <span class="name-button">Relatórios</span>
          </a>
        </li>

        <li class="nav-item mb-2">
          <a href="#" class="btn btn-outline-secondary text-light sidebar-btn d-flex align-items-center gap-2" 
             style="transition: all 0.3s ease;">
            <i class="fa fa-cog"></i>
            <span class="name-button">Configurações</span>
          </a>
        </li>
      </ul>

      <!-- Footer Section -->
      <div class="mt-auto pt-3 border-top border-secondary">
        <div class="d-flex align-items-center gap-2 text-muted">
          <i class="fa fa-user-circle fa-2x"></i>
          <div class="small">
            <div class="text-light fw-semibold">Usuário</div>
            <div style="font-size: 0.7rem;">Online</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</aside>

<style>
  /* Enhanced sidebar styling */
  .left-menu {
    min-height: 100vh;
    position: fixed;
    left: 0;
    top: 0;
    width: 260px;
    z-index: 1000;
  }

  .aside-inner {
    height: 100vh;
    overflow-y: auto;
    padding: 1rem 0;
  }

  /* Scrollbar Customization */
  .aside-inner::-webkit-scrollbar {
    width: 6px;
  }

  .aside-inner::-webkit-scrollbar-track {
    background: #1a1d29;
  }

  .aside-inner::-webkit-scrollbar-thumb {
    background: #3d4153;
    border-radius: 3px;
  }

  .aside-inner::-webkit-scrollbar-thumb:hover {
    background: #4d5163;
  }

  /* Button Hover Effects */
  .sidebar-btn {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 500;
    width: 100%;
    text-align: left;
  }

  .sidebar-btn:hover {
    transform: translateX(5px);
    box-shadow: 0 4px 12px rgba(23, 162, 184, 0.3);
  }

  .btn-outline-info:hover {
    background-color: rgba(23, 162, 184, 0.15);
    border-color: #17a2b8;
  }

  .btn-outline-secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }

  /* Active State */
  .sidebar-btn.active {
    background: linear-gradient(135deg, #17a2b8 0%, #138496 100%);
    color: white !important;
    box-shadow: 0 4px 12px rgba(23, 162, 184, 0.4);
  }

  /* Icon Styling */
  .sidebar-btn i {
    font-size: 1.1rem;
    min-width: 24px;
  }

  /* Badge Animation */
  .badge {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% {
      opacity: 1;
    }
    50% {
      opacity: 0.7;
    }
  }

  /* Responsive */
  @media (max-width: 768px) {
    .left-menu {
      width: 200px;
    }
  }
</style>
