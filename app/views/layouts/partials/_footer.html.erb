<footer class="crm-footer">

  <div class="crm-footer__container">

    <div class="crm-footer__brand">
      <%= image_tag 'admin/logo-novo.png', class: 'crm-footer__logo' %>

      <p class="crm-footer__description">
        Plataforma CRM para gestão inteligente de clientes,
        pedidos e produtos.
      </p>
    </div>

    <div class="crm-footer__column">

      <span class="crm-footer__title">Sistema</span>

      <%= link_to painel_path, class: "crm-footer__link" do %>Dashboard<% end %>
      <%= link_to customers_path, class: "crm-footer__link" do %>Clientes<% end %>
      <%= link_to orders_path, class: "crm-footer__link" do %>Pedidos<% end %>
      <%= link_to products_path, class: "crm-footer__link" do %>Produtos<% end %>

    </div>

    <% if current_user.admin? %>
    <div class="crm-footer__column">

      <span class="crm-footer__title">Administração</span>

      <%= link_to users_path, class: "crm-footer__link" do %>Usuários<% end %>
      <%= link_to profiles_path, class: "crm-footer__link" do %>Perfis<% end %>
      <%= link_to "/painel/sidekiq", class: "crm-footer__link" do %>Sidekiq<% end %>

    </div>
    <% end %>

    <div class="crm-footer__support">

      <span class="crm-footer__title">Suporte</span>

      <p class="crm-footer__support-text">
        Precisa de ajuda? Nossa equipe está pronta para atender você.
      </p>

      <a
        href="https://wa.me/5516991997608?text=Olá,%20preciso%20de%20suporte%20no%20CRM."
        target="_blank"
        class="crm-footer__whatsapp"
      >
        Falar no WhatsApp
      </a>

    </div>

  </div>

  <div class="crm-footer__bottom">
    <span>&copy; <%= Date.today.year %> MEWTDA CRM</span>
    <span class="crm-footer__version">v1.0</span>
  </div>

</footer>

<style>

.crm-footer{
  background:#ffffff;
  border-top:1px solid #e5e7eb;
}

.crm-footer__container{
  max-width:1200px;
  margin:auto;
  padding:40px 24px;
  display:grid;
  grid-template-columns:2fr 1fr 1fr 1.4fr;
  gap:40px;
}

.crm-footer__logo{
  width: 140px;
}

.crm-footer__description{
  margin-top:10px;
  font-size:14px;
  line-height:1.6;
  color:#6b7280;
  max-width:260px;
}

.crm-footer__column{
  display:flex;
  flex-direction:column;
  gap:8px;
}

.crm-footer__title{
  font-size:12px;
  font-weight:700;
  letter-spacing:.08em;
  text-transform:uppercase;
  color:#9ca3af;
  margin-bottom:6px;
}

.crm-footer__link{
  font-size:14px;
  color:#374151;
  text-decoration:none;
  transition:.15s;
}

.crm-footer__link:hover{
  color:#4f46e5;
}

.crm-footer__support{
  display:flex;
  flex-direction:column;
  gap:10px;
}

.crm-footer__support-text{
  font-size:14px;
  color:#6b7280;
}

.crm-footer__whatsapp{
  display:inline-block;
  background:#25d366;
  color:#fff;
  text-decoration:none;
  padding:10px 16px;
  border-radius:8px;
  font-size:14px;
  font-weight:600;
  width:fit-content;
  transition:.15s;
}

.crm-footer__whatsapp:hover{
  background:#1ebe5d;
}

.crm-footer__bottom{
  border-top:1px solid #e5e7eb;
  padding:14px 24px;
  display:flex;
  justify-content:space-between;
  font-size:12px;
  color:#9ca3af;
}

.crm-footer__version{
  opacity:.7;
}

@media (max-width:900px){

  .crm-footer__container{
    grid-template-columns:1fr;
    gap:28px;
  }

  .crm-footer__bottom{
    flex-direction:column;
    gap:6px;
    text-align:center;
  }

}

</style>
