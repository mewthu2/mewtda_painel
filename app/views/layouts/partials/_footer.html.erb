<footer class="crm-footer">
  <div class="crm-footer__inner">

    <div class="crm-footer__brand">
      <%= image_tag 'admin/logo-store', class: 'crm-footer__logo', alt: 'Logo' %>
      <p class="crm-footer__tagline">Gestão inteligente para o seu negócio.</p>
    </div>

    <div class="crm-footer__links">
      <span class="crm-footer__links-title">Navegação</span>
      <%= link_to root_path, class: 'crm-footer__link' do %>Home<% end %>
      <%= link_to customers_path, class: 'crm-footer__link' do %>Clientes<% end %>
      <%= link_to orders_path, class: 'crm-footer__link' do %>Pedidos<% end %>
      <%= link_to products_path, class: 'crm-footer__link' do %>Produtos<% end %>
      <%= link_to '#', class: 'crm-footer__link' do %>Relatórios<% end %>
      <%= link_to '#', class: 'crm-footer__link' do %>Configurações<% end %>
    </div>

    <div class="crm-footer__support">
      <span class="crm-footer__links-title">Suporte</span>
      <p class="crm-footer__support-text">Dúvidas ou problemas? Fale com a nossa equipe diretamente pelo WhatsApp.</p>
      <a href="https://wa.me/5516991997608?text=Olá,%20preciso%20de%20suporte%20no%20CRM."
         target="_blank"
         rel="noopener noreferrer"
         class="crm-footer__whatsapp-btn">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="crm-footer__whatsapp-icon" fill="currentColor">
          <path d="M16 0C7.163 0 0 7.163 0 16c0 2.822.736 5.476 2.027 7.782L0 32l8.418-2.004A15.934 15.934 0 0016 32c8.837 0 16-7.163 16-16S24.837 0 16 0zm0 29.333a13.28 13.28 0 01-6.79-1.862l-.486-.29-5.002 1.19 1.23-4.863-.317-.5A13.282 13.282 0 012.667 16C2.667 8.636 8.636 2.667 16 2.667S29.333 8.636 29.333 16 23.364 29.333 16 29.333zm7.23-9.953c-.396-.198-2.344-1.157-2.708-1.288-.363-.132-.627-.198-.89.198-.264.396-1.023 1.288-1.254 1.552-.23.264-.462.297-.858.099-.396-.198-1.672-.617-3.185-1.966-1.176-1.051-1.97-2.349-2.201-2.745-.23-.396-.024-.61.173-.807.178-.177.396-.462.594-.693.198-.23.264-.396.396-.66.132-.264.066-.495-.033-.693-.099-.198-.89-2.148-1.22-2.94-.32-.772-.647-.667-.89-.68l-.759-.013c-.264 0-.693.099-.857.264-.297.33-1.122 1.157-1.122 2.82 0 1.666 1.188 3.277 1.353 3.507.165.23 2.34 3.573 5.67 5.007.792.342 1.41.547 1.89.7.794.253 1.517.218 2.088.132.637-.095 1.96-.8 2.237-1.572.277-.771.277-1.432.194-1.57-.082-.132-.297-.21-.693-.41z"/>
        </svg>
        Chamar no WhatsApp
      </a>
    </div>

  </div>

  <div class="crm-footer__bottom">
    <span>&copy; <%= Date.today.year %> MEWTDA - CRM &mdash; Todos os direitos reservados.</span>
  </div>
</footer>

<style>
  .crm-footer {
    background: #ffffff;
    border-top: 1px solid #e4e7f0;
    margin-top: 3rem;
  }

  .crm-footer__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 2rem;
    display: flex;
    gap: 3rem;
    flex-wrap: wrap;
    align-items: flex-start;
  }

  .crm-footer__brand {
    flex: 1 1 200px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .crm-footer__logo {
    width: 100px;
    height: 100px;
    object-fit: contain;
  }

  .crm-footer__tagline {
    margin: 0;
    font-size: 0.875rem;
    color: #6b7494;
    line-height: 1.5;
    max-width: 220px;
  }

  .crm-footer__links {
    flex: 1 1 160px;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .crm-footer__links-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #9097b5;
    margin-bottom: 0.25rem;
  }

  .crm-footer__link {
    font-size: 0.875rem;
    color: #3d4560;
    text-decoration: none;
    transition: color 0.15s ease;
    padding: 0.15rem 0;
  }

  .crm-footer__link:hover {
    color: #3b4adf;
  }

  .crm-footer__support {
    flex: 1 1 240px;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .crm-footer__support-text {
    margin: 0;
    font-size: 0.875rem;
    color: #6b7494;
    line-height: 1.55;
  }

  .crm-footer__whatsapp-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    background: #25d366;
    color: #ffffff;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 600;
    padding: 0.6rem 1.2rem;
    border-radius: 8px;
    transition: background 0.15s ease, transform 0.1s ease;
    width: fit-content;
  }

  .crm-footer__whatsapp-btn:hover {
    background: #1ebe5d;
    transform: translateY(-1px);
  }

  .crm-footer__whatsapp-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }

  .crm-footer__bottom {
    border-top: 1px solid #e4e7f0;
    padding: 1rem 2rem;
    text-align: center;
    font-size: 0.8rem;
    color: #9097b5;
  }
</style>
