          <div class="ev-funnel__rate">100%</div>
        </div>

        <div class="ev-funnel__step">
          <div class="ev-funnel__icon" style="background:rgba(34,197,94,.15)">
            <svg width="20" height="20" fill="none" stroke="#22c55e" stroke-width="2" viewBox="0 0 24 24"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <div class="ev-funnel__count"><%= number_with_delimiter(@counts[:product_viewed]) %></div>
          <div class="ev-funnel__name">Produtos Vistos</div>
          <div class="ev-funnel__bar">
            <div class="ev-funnel__bar-fill" style="width:<%= @conversion[:product_viewed] %>%; background:#22c55e"></div>
          </div>
          <div class="ev-funnel__rate"><%= @conversion[:product_viewed] %>%</div>
          <div class="ev-funnel__dropoff"><%= @dropoff[:page_to_product] %>% saiu</div>
          <% if @avg_times[:page_to_product] > 0 %>
            <div class="ev-funnel__time">
              <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <%= @avg_times[:page_to_product] %> min
            </div>
          <% end %>
        </div>

        <div class="ev-funnel__step">
          <div class="ev-funnel__icon" style="background:rgba(245,158,11,.15)">
            <svg width="20" height="20" fill="none" stroke="#f59e0b" stroke-width="2" viewBox="0 0 24 24"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13l-1.35 2.7A1 1 0 007 17h11M7 13l-.4-2M17 17a2 2 0 100 4 2 2 0 000-4zm-8 0a2 2 0 100 4 2 2 0 000-4z"/></svg>
          </div>
          <div class="ev-funnel__count"><%= number_with_delimiter(@counts[:added_to_cart]) %></div>
          <div class="ev-funnel__name">Add ao Carrinho</div>
          <div class="ev-funnel__bar">
            <div class="ev-funnel__bar-fill" style="width:<%= @conversion[:added_to_cart] %>%; background:#f59e0b"></div>
          </div>
          <div class="ev-funnel__rate"><%= @conversion[:added_to_cart] %>%</div>
          <div class="ev-funnel__dropoff"><%= @dropoff[:product_to_cart] %>% saiu</div>
          <% if @avg_times[:product_to_cart] > 0 %>
            <div class="ev-funnel__time">
              <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
              <%= @avg_times[:product_to_cart] %> min
            </div>
          <% end %>
        </div>

        <div class="ev-funnel__step">
          <div class="ev-funnel__icon" style="background:rgba(236,72,153,.15)">
            <svg width="20" height="20" fill="none" stroke="#ec4899" stroke-width="2" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <div class="ev-funnel__count"><%= number_with_delimiter(@counts[:checkout_completed]) %></div>
          <div class="ev-funnel__name">Checkout</div>
          <div class="ev-funnel__bar">
            <div class="ev-funnel__bar-fill" style="width:<%= @conversion[:checkout_completed] %>%; background:#ec4899"></div>
          </div>
          <div class="ev-funnel__rate"><%= @conversion[:checkout_completed] %>%</div>
          <div class="ev-funnel__dropoff"><%= @dropoff[:cart_to_checkout] %>% nao converteu</div>
          <% if @avg_times[:cart_to_checkout] > 0 %>
            <div class="ev-funnel__time">
              <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
