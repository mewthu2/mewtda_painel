    <div class="ev-card" style="margin-bottom:24px">
      <div class="ev-card__header">
        <span class="ev-card__title">Atividade por Hora do Dia</span>
      </div>
      <% max_hour = @hourly_events.values.max || 1 %>
      <div class="ev-heatmap">
        <% @hourly_events.each do |hour, count| %>
          <%
            intensity = count.to_f / max_hour
            bg = if intensity == 0
              '#f1f5f9'
            elsif intensity < 0.25
              '#dbeafe'
            elsif intensity < 0.5
              '#93c5fd'
            elsif intensity < 0.75
              '#3b82f6'
            else
              '#1d4ed8'
            end
            text_color = intensity >= 0.5 ? '#fff' : '#64748b'
          %>
          <div
            class="ev-heatmap__cell"
            style="background:<%= bg %>; color:<%= text_color %>"
            data-tooltip="<%= hour %>h: <%= count %> eventos"
          >
            <%= count > 0 ? count : '' %>
          </div>
        <% end %>
      </div>
      <div class="ev-heatmap__labels">
        <% (0..23).each do |h| %>
          <span class="ev-heatmap__label"><%= h.to_s.rjust(2, '0') %></span>
        <% end %>
      </div>
    </div>


    <div class="ev-grid-2">
      <div class="ev-card">
        <div class="ev-card__header">
          <span class="ev-card__title">Atividade por Dia da Semana</span>
        </div>
        <div class="ev-chart-wrap">
          <div id="weekday_chart"></div>
        </div>
      </div>

      <div class="ev-card">
        <div class="ev-card__header">
          <span class="ev-card__title">Funil Comparativo</span>
        </div>
        <div class="ev-chart-wrap">
          <div id="funnel_bar_chart"></div>
        </div>
      </div>
    </div>


    <div class="ev-table-card">
      <div class="ev-table-card__header">
        <span class="ev-table-card__title">Sessoes Recentes</span>
        <span class="ev-table-card__count"><%= @sessions.size %> sessoes | <%= @sessions.count { |s| !s[:abandoned] } %> convertidas</span>
      </div>

      <div class="ev-table-wrap">
        <table class="ev-table">
          <thead>
            <tr>
              <th>Sessao</th>
              <th>Dominio</th>
              <th>Jornada</th>
              <th class="center">Device</th>
              <th class="center">Duracao</th>
              <th class="center">Eventos</th>
              <th class="center">Status</th>
            </tr>
          </thead>

          <tbody>
            <% if @sessions.empty? %>
              <tr>
                <td colspan="7" class="ev-table__empty">
                  Nenhuma sessao encontrada no periodo selecionado.
                </td>
              </tr>
            <% else %>
              <% @sessions.each do |s| %>
                <tr
                  class="ev-session-row <%= 'ev-table__row--abandoned' if s[:abandoned] %>"
                  data-session-id="<%= s[:session_id] %>"
                  data-fetch-url="<%= session_events_path(session_id: s[:session_id]) %>"
                >
                  <td>
                    <span class="ev-badge ev-badge--mono"><%= s[:session_id].truncate(12) %></span>
                  </td>
                  <td style="font-weight:500; color:#0f172a"><%= s[:shop_domain] %></td>
                  <td>
                    <div style="display:flex; gap:4px; flex-wrap:wrap">
                      <% s[:last_kinds].each do |kind| %>
                        <%
                          badge_class = case kind
                            when 'page_viewed'           then 'ev-badge--page'
                            when 'product_viewed'        then 'ev-badge--product'
                            when 'product_added_to_cart' then 'ev-badge--cart'
                            when 'checkout_started'      then 'ev-badge--cart'
                            when 'checkout_completed'    then 'ev-badge--checkout'
                            else ''
                          end
                        %>
                        <span class="ev-badge <%= badge_class %>"><%= kind.split('_').first(2).join(' ') %></span>
                      <% end %>
                    </div>
                  </td>
                  <td class="center">
                    <span class="ev-badge ev-badge--device"><%= s[:device] %></span>
                  </td>
                  <td class="center" style="color:#64748b; font-size:12px"><%= s[:duration_min] %> min</td>
                  <td class="center">
                    <span class="ev-badge ev-badge--count"><%= s[:event_count] %></span>
                  </td>
                  <td class="center">
                    <% if s[:abandoned] %>
                      <span class="ev-badge ev-badge--abandoned">nao converteu</span>
                    <% else %>
                      <span class="ev-badge" style="background:#dcfce7; color:#15803d">converteu</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

  <% end %>

</div>


<div id="ev-modal-overlay" class="ev-modal-overlay" role="dialog" aria-modal="true">
