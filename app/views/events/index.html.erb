      <div class="ev-card">
        <div class="ev-card__header">
          <span class="ev-card__title">Origem do Trafego</span>
        </div>
        <div class="ev-chart-wrap">
          <div id="referrers_chart"></div>
        </div>
      </div>

      <div class="ev-card">
        <div class="ev-card__header">
          <span class="ev-card__title">Top Produtos Vistos</span>
        </div>
        <% if @top_products_viewed.any? %>
          <ul class="ev-top-list ev-top-list--products">
            <% @top_products_viewed.each_with_index do |p, i| %>
              <li>
                <span class="ev-top-list__rank"><%= i + 1 %></span>
                <% if p[:image].present? %>
                  <img
                    src="<%= p[:image].start_with?('//') ? "https:#{p[:image]}" : p[:image] %>"
                    alt="<%= p[:title] %>"
                    class="ev-top-list__img"
                    loading="lazy"
                  />
                <% else %>
                  <span class="ev-top-list__img-placeholder">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
                  </span>
                <% end %>
                <div class="ev-top-list__info">
                  <span class="ev-top-list__title"><%= p[:title] %></span>
                  <% if p[:sku].present? %>
                    <span class="ev-top-list__sku">SKU: <%= p[:sku] %></span>
                  <% elsif p[:price].present? && p[:price].to_f > 0 %>
                    <span class="ev-top-list__price">
                      <%= number_to_currency(p[:price], unit: "R$ ", separator: ",", delimiter: ".") %>
                    </span>
                  <% end %>
                </div>
                <span class="ev-top-list__count"><%= p[:count] %></span>
              </li>
            <% end %>
