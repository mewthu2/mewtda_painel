<script>
document.addEventListener("DOMContentLoaded", function () {
  var COLORS = ['#3b82f6', '#22c55e', '#f59e0b', '#ec4899', '#8b5cf6'];

  new ApexCharts(document.querySelector("#events_chart"), {
    chart: { type: 'area', height: 220, toolbar: { show: false }, fontFamily: 'inherit' },
    series: [
      { name: 'Page',     data: <%= raw @daily_events.select{|k,_| k[1]=='page_viewed'}.map{|k,v| [k[0],v]}.to_json %> },
      { name: 'Produto',  data: <%= raw @daily_events.select{|k,_| k[1]=='product_viewed'}.map{|k,v| [k[0],v]}.to_json %> },
      { name: 'Carrinho', data: <%= raw @daily_events.select{|k,_| k[1]=='product_added_to_cart'}.map{|k,v| [k[0],v]}.to_json %> },
      { name: 'Checkout', data: <%= raw @daily_events.select{|k,_| k[1]=='checkout_completed'}.map{|k,v| [k[0],v]}.to_json %> }
    ],
    xaxis: { type: 'datetime', labels: { style: { fontSize: '11px' } } },
    colors: COLORS,
    fill: { type: 'gradient', gradient: { shadeIntensity: 1, opacityFrom: 0.3, opacityTo: 0.05 } },
    stroke: { width: 2, curve: 'smooth' },
    legend: { fontSize: '11px', position: 'top' },
    grid: { borderColor: '#f1f5f9' },
    tooltip: { theme: 'light', x: { format: 'dd/MM' } }
  }).render();

  new ApexCharts(document.querySelector("#devices_chart"), {
    chart: { type: 'donut', height: 220, fontFamily: 'inherit' },
    series: [<%= @devices[:desktop] %>, <%= @devices[:mobile] %>, <%= @devices[:tablet] %>],
    labels: ['Desktop', 'Mobile', 'Tablet'],
    colors: ['#3b82f6', '#22c55e', '#f59e0b'],
    legend: { position: 'bottom', fontSize: '12px' },
    plotOptions: { pie: { donut: { size: '60%', labels: { show: true, total: { show: true, label: 'Total', fontSize: '14px', fontWeight: 700 } } } } },
    dataLabels: { enabled: false }
  }).render();

  new ApexCharts(document.querySelector("#referrers_chart"), {
    chart: { type: 'bar', height: 220, toolbar: { show: false }, fontFamily: 'inherit' },
    series: [{ name: 'Visitas', data: <%= raw @referrers.values.to_json %> }],
    xaxis: { categories: <%= raw @referrers.keys.to_json %> },
    colors: ['#8b5cf6'],
    plotOptions: { bar: { horizontal: true, borderRadius: 4 } },
    grid: { borderColor: '#f1f5f9' },
    dataLabels: { enabled: true, style: { fontSize: '11px' } }
  }).render();

  new ApexCharts(document.querySelector("#weekday_chart"), {
    chart: { type: 'bar', height: 200, toolbar: { show: false }, fontFamily: 'inherit' },
    series: [{ name: 'Eventos', data: <%= raw @weekday_events.map{|d| d[:count]}.to_json %> }],
    xaxis: { categories: <%= raw @weekday_events.map{|d| d[:day]}.to_json %> },
    colors: ['#3b82f6'],
    plotOptions: { bar: { borderRadius: 4, columnWidth: '55%' } },
    grid: { borderColor: '#f1f5f9' },
    dataLabels: { enabled: false }
  }).render();

  new ApexCharts(document.querySelector("#funnel_bar_chart"), {
    chart: { type: 'bar', height: 200, toolbar: { show: false }, fontFamily: 'inherit' },
    series: [{ name: 'Eventos', data: [<%= @counts[:page_viewed] %>, <%= @counts[:product_viewed] %>, <%= @counts[:added_to_cart] %>, <%= @counts[:checkout_completed] %>] }],
    xaxis: { categories: ['Paginas', 'Produtos', 'Carrinho', 'Checkout'] },
    colors: COLORS,
    plotOptions: { bar: { distributed: true, borderRadius: 6, columnWidth: '50%' } },
    legend: { show: false },
    grid: { borderColor: '#f1f5f9' },
    dataLabels: { enabled: true, style: { fontSize: '12px', fontWeight: 700 } }
  }).render();
});
</script>

<script>
(function () {
  var KIND_BADGE = {
    page_viewed:           'ev-badge--page',
    product_viewed:        'ev-badge--product',
    product_added_to_cart: 'ev-badge--cart',
    checkout_started:      'ev-badge--cart',
    checkout_completed:    'ev-badge--checkout'
  };

  function fmtDate(str) { return new Date(str).toLocaleString('pt-BR'); }

  function chip(label, value) {
    return '<div class="ev-modal__chip"><span style="color:#94a3b8">' + label + '</span> <strong>' + value + '</strong></div>';
  }

  function renderEvent(e) {
    var ctx = e.context || {}, doc = ctx.document || {}, nav = ctx.navigator || {}, win = ctx.window || {}, loc = doc.location || {}, scr = win.screen || {};
    var url = loc.href, title = doc.title, referrer = doc.referrer, ua = nav.userAgent;
    var screen = (scr.width && scr.height) ? scr.width + 'x' + scr.height : null;
    var hasData = e.data && typeof e.data === 'object' && Object.keys(e.data).length > 0;
    var badgeCls = KIND_BADGE[e.kind] || '';

    var html = '<div class="ev-event">';
    html += '<div class="ev-event__head">';
    html += '<span class="ev-badge ' + badgeCls + '">' + (e.kind || '').replace(/_/g,' ') + '</span>';
    html += '<span class="ev-event__time">' + fmtDate(e.created_at) + '</span>';
    html += '</div>';
    if (title) html += '<div class="ev-event__row"><strong>Titulo:</strong> ' + title + '</div>';
    if (url) html += '<div class="ev-event__row" style="word-break:break-all"><strong>URL:</strong> <a href="' + url + '" target="_blank">' + url + '</a></div>';
    if (referrer) html += '<div class="ev-event__row" style="word-break:break-all"><strong>Referrer:</strong> ' + referrer + '</div>';
    if (screen) html += '<div class="ev-event__row"><strong>Tela:</strong> ' + screen + '</div>';
    if (ua) html += '<div class="ev-event__row ev-event__row--muted">' + ua + '</div>';
    if (hasData) {
      html += '<details><summary>Ver dados</summary><pre>' + JSON.stringify(e.data, null, 2) + '</pre></details>';
    }
    html += '</div>';
    return html;
  }

  document.querySelectorAll('.ev-session-row').forEach(function (row) {
    row.addEventListener('click', function () {
      var sid = this.dataset.sessionId, url = this.dataset.fetchUrl;
      document.getElementById('ev-modal-sid').textContent = sid;
      document.getElementById('ev-modal-meta').innerHTML = '';
      document.getElementById('ev-modal-events-list').innerHTML = '';
      document.getElementById('ev-modal-loading').style.display = 'block';
      document.getElementById('ev-modal-loading').textContent = 'Carregando...';
      document.getElementById('ev-modal-events').style.display = 'none';
      document.getElementById('ev-modal-overlay').style.display = 'block';
      document.body.style.overflow = 'hidden';

      fetch(url, { method: 'GET', credentials: 'same-origin', headers: { 'Accept': 'application/json', 'X-CSRF-Token': (document.querySelector('meta[name="csrf-token"]') || {}).content || '' } })
        .then(function (r) { if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
        .then(function (data) {
          var meta = '';
          meta += chip('Dominio', data.shop_domain || '-');
          meta += chip('Inicio', fmtDate(data.started_at));
          meta += chip('Fim', fmtDate(data.last_at));
          meta += chip('Eventos', data.event_count);
          document.getElementById('ev-modal-meta').innerHTML = meta;
          document.getElementById('ev-modal-events-list').innerHTML = (data.events || []).map(renderEvent).join('');
          document.getElementById('ev-modal-loading').style.display = 'none';
          document.getElementById('ev-modal-events').style.display = 'block';
        })
        .catch(function () { document.getElementById('ev-modal-loading').textContent = 'Erro ao carregar. Tente novamente.'; });
    });
  });

  function closeModal() { document.getElementById('ev-modal-overlay').style.display = 'none'; document.body.style.overflow = ''; }
  document.getElementById('ev-modal-close').addEventListener('click', closeModal);
  document.getElementById('ev-modal-overlay').addEventListener('click', function (e) { if (e.target === this) closeModal(); });
  document.addEventListener('keydown', function (e) { if (e.key === 'Escape') closeModal(); });
}());
</script>
<% end %>
