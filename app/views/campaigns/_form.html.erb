<script>
  function updateCampaignLabels() {
    const kind = document.getElementById('campaign_kind').value;
    const labelText = document.getElementById('label_text_days');
    const hintDays = document.getElementById('hint_days');
    const sectionTitle = document.getElementById('message_section_title');
    const hintCashback = document.getElementById('hint_cashback');
    const hintExpiration = document.getElementById('hint_expiration');
    const hintMarketing = document.getElementById('hint_marketing');
    const sectionEnvio = document.getElementById('section_envio');
    const sectionFiltros = document.getElementById('section_filtros');
    const variablesCashback = document.getElementById('variables_cashback');
    const variablesMarketing = document.getElementById('variables_marketing');

    // Esconder todos os hints primeiro
    hintCashback.style.display = 'none';
    hintExpiration.style.display = 'none';
    hintMarketing.style.display = 'none';
    variablesCashback.style.display = 'none';
    variablesMarketing.style.display = 'none';

    if (kind === 'marketing_notification') {
      // Marketing notification
      sectionEnvio.style.display = 'none';
      sectionFiltros.style.display = '';
      sectionTitle.textContent = 'Mensagem da Campanha';
      hintMarketing.style.display = '';
      variablesMarketing.style.display = '';
    } else if (kind === 'cashback_expiration') {
      // Cashback expiration
      sectionEnvio.style.display = '';
      sectionFiltros.style.display = 'none';
      labelText.textContent = 'Dias antes da expiracao';
      hintDays.textContent = 'Quantos dias antes de expirar o cupom o cliente recebe o lembrete';
      sectionTitle.textContent = 'Mensagem de Lembrete de Expiracao';
      hintExpiration.style.display = '';
      variablesCashback.style.display = '';
    } else {
      // Cashback padrao
      sectionEnvio.style.display = '';
      sectionFiltros.style.display = 'none';
      labelText.textContent = 'Dias apos a compra';
      hintDays.textContent = 'Quantos dias apos a compra o cliente recebe a mensagem de cashback';
      sectionTitle.textContent = 'Mensagem de Cashback';
      hintCashback.style.display = '';
      variablesCashback.style.display = '';
    }
  }

  document.addEventListener('DOMContentLoaded', function () {
    updateCampaignLabels();
  });
</script>
