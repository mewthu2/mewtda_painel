<% title 'Novo Afiliado' %>

<div class="affiliates-wrapper">

  <div class="affiliates-page-header">
    <div class="affiliates-page-header__left">
      <%= link_to affiliates_path, class: 'affiliates-btn affiliates-btn--secondary' do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Voltar
      <% end %>
      <h1 class="affiliates-page-header__title">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 7.5v3m0 0v3m0-3h3m-3 0h-3m-2.25-4.125a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zM4 19.235v-.11a6.375 6.375 0 0112.75 0v.109A12.318 12.318 0 0110.374 21c-2.331 0-4.512-.645-6.374-1.766z" />
        </svg>
        Novo Afiliado
      </h1>
    </div>
  </div>

  <div class="affiliates-form-wrap">
    <%= render 'form', form_url: affiliates_path, form_method: :post %>
  </div>

</div>

<%= render 'form_styles' %>
