<%= form_for @affiliate, url: form_url, html: { class: 'affiliates-form', method: form_method } do |f| %>

  <div class="affiliates-form__card-header">
    <div class="affiliates-form__card-header-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
      </svg>
    </div>
    <div>
      <h2 class="affiliates-form__card-title"><%= @affiliate.new_record? ? 'Novo Afiliado' : 'Editar Afiliado' %></h2>
      <p class="affiliates-form__card-subtitle">Cliente: <%= current_client.name %></p>
    </div>
  </div>

  <% if @affiliate.errors.any? %>
    <div class="affiliates-form__errors">
      <strong>Erros encontrados:</strong>
      <ul>
        <% @affiliate.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="affiliates-form__section">
    <h2 class="affiliates-form__section-title">Informações Básicas</h2>
    
    <div class="affiliates-form__row">
      <div class="affiliates-form__field">
        <label for="user_name">Nome *</label>
        <%= f.text_field :name, class: 'affiliates-form__input', placeholder: 'Nome completo do afiliado', required: true %>
      </div>
    </div>

    <div class="affiliates-form__row affiliates-form__row--two">
      <div class="affiliates-form__field">
        <label for="user_email">E-mail *</label>
        <%= f.email_field :email, class: 'affiliates-form__input', placeholder: 'email@exemplo.com', required: true %>
      </div>
      <div class="affiliates-form__field">
        <label for="user_phone">Telefone</label>
        <%= f.text_field :phone, class: 'affiliates-form__input', placeholder: '(00) 00000-0000' %>
      </div>
    </div>
  </div>

  <div class="affiliates-form__section">
    <h2 class="affiliates-form__section-title">Código de Rastreamento</h2>
    
    <div class="affiliates-form__row">
      <div class="affiliates-form__field">
        <label for="user_utm_code">Código UTM *</label>
        <%= f.text_field :utm_code, class: 'affiliates-form__input', placeholder: 'codigo-unico-afiliado', required: true %>
        <span class="affiliates-form__hint">
          Este código será usado para rastrear as vendas do afiliado via <code>utm_affiliate=<%= @affiliate.utm_code.presence || 'codigo' %></code>. 
          Use apenas letras minúsculas, números e hífens.
        </span>
      </div>
    </div>

    <div class="affiliates-form__row">
      <div class="affiliates-form__field">
        <label for="user_discount_code">Cupom de Desconto</label>
        <%= f.text_field :discount_code, class: 'affiliates-form__input', placeholder: 'Ex: AFILIADO10' %>
        <span class="affiliates-form__hint">
          Código de cupom exclusivo do afiliado. Será exibido no painel e pode ser divulgado pelo afiliado para seus clientes.
          Use letras maiúsculas, números e hífens (ex: <code>JOAO10</code>, <code>PARCEIRO-20</code>).
        </span>
      </div>
    </div>
  </div>

  <div class="affiliates-form__section">
    <h2 class="affiliates-form__section-title"><%= @affiliate.new_record? ? 'Senha de Acesso' : 'Alterar Senha' %></h2>
    <p class="affiliates-form__section-desc">
      <% if @affiliate.new_record? %>
        Defina uma senha para o afiliado acessar o sistema. Se deixar em branco, uma senha temporária será gerada.
      <% else %>
        Deixe em branco se não quiser alterar a senha.
      <% end %>
    </p>
    
    <div class="affiliates-form__row affiliates-form__row--two">
      <div class="affiliates-form__field">
        <label for="user_password"><%= @affiliate.new_record? ? 'Senha' : 'Nova Senha' %></label>
        <%= f.password_field :password, class: 'affiliates-form__input', placeholder: 'Mínimo 6 caracteres' %>
      </div>
      <div class="affiliates-form__field">
        <label for="user_password_confirmation">Confirmar Senha</label>
        <%= f.password_field :password_confirmation, class: 'affiliates-form__input', placeholder: 'Repita a senha' %>
      </div>
    </div>
  </div>

  <div class="affiliates-form__actions">
    <%= link_to affiliates_path, class: 'affiliates-btn affiliates-btn--secondary' do %>
      Cancelar
    <% end %>
    <%= f.submit (@affiliate.new_record? ? 'Criar Afiliado' : 'Salvar Alterações'), class: "affiliates-btn #{@affiliate.new_record? ? 'affiliates-btn--success' : 'affiliates-btn--primary'}" %>
  </div>
<% end %>

<style>
  .affiliates-form__card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: #f0fdf4;
    border-bottom: 1px solid #bbf7d0;
    border-radius: 0.5rem 0.5rem 0 0;
  }

  .affiliates-form__card-header-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 0.5rem;
    background: #16a34a;
    color: #fff;
    flex-shrink: 0;
  }

  .affiliates-form__card-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #14532d;
    margin: 0;
    line-height: 1.3;
  }

  .affiliates-form__card-subtitle {
    font-size: 0.8rem;
    color: #16a34a;
    margin: 0.15rem 0 0;
    font-weight: 500;
  }
</style>
