<% title 'Editar Afiliado' %>

<div class="affiliates-wrapper">

  <div class="affiliates-page-header">
    <div class="affiliates-page-header__left">
      <%= link_to affiliates_path, class: 'affiliates-btn affiliates-btn--secondary' do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
        </svg>
        Voltar
      <% end %>
      <h1 class="affiliates-page-header__title">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
        </svg>
        Editar Afiliado
      </h1>
    </div>
    <div class="affiliates-page-header__meta">
      <span class="affiliates-table__badge affiliates-table__badge--utm">ID #<%= @affiliate.id %></span>
      <span class="affiliates-page-header__name"><%= @affiliate.name %></span>
    </div>
  </div>

  <div class="affiliates-form-wrap">
    <%= render 'form', form_url: affiliate_path(@affiliate), form_method: :patch %>
  </div>

</div>

<%= render 'form_styles' %>
