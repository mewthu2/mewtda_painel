<% title "#{@affiliate.name} - Analytics" %>

<div class="aff-page">

  <%# Header %>
  <div class="aff-header">
    <div class="aff-header__left">
      <div class="aff-header__breadcrumb">
        <%= link_to affiliates_path, class: 'aff-header__back-link' do %>
          <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" /></svg>
          Afiliados
        <% end %>
        <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 18l6-6-6-6"/></svg>
        <span class="aff-header__name"><%= @affiliate.name %></span>
      </div>
      <h1 class="aff-header__title">Analytics do Afiliado</h1>
      <p class="aff-header__subtitle">
        Rastreamento via <code class="aff-utm-code">utm_affiliate=<%= @affiliate.utm_code %></code>
      </p>
    </div>

    <div class="aff-header__right">
      <div class="aff-filters">
        <%= link_to affiliate_path(@affiliate, period: "7"),  class: "aff-filter-btn #{'aff-filter-btn--active' if @period == '7'}" %>7 dias<% end %>
        <%= link_to affiliate_path(@affiliate, period: "15"), class: "aff-filter-btn #{'aff-filter-btn--active' if @period == '15'}" %>15 dias<% end %>
        <%= link_to affiliate_path(@affiliate, period: "30"), class: "aff-filter-btn #{'aff-filter-btn--active' if @period == '30'}" %>30 dias<% end %>
        <%= link_to affiliate_path(@affiliate, period: "90"), class: "aff-filter-btn #{'aff-filter-btn--active' if @period == '90'}" %>90 dias<% end %>
      </div>
      <%= link_to edit_affiliate_path(@affiliate), class: 'aff-btn aff-btn--secondary' do %>
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931z" /></svg>
        Editar
      <% end %>
    </div>
  </div>

  <%# Info Card %>
  <div class="aff-info-card">
    <div class="aff-info-card__avatar">
      <svg width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
      </svg>
    </div>
    <div class="aff-info-card__details">
      <div class="aff-info-card__name"><%= @affiliate.name %></div>
      <div class="aff-info-card__email"><%= @affiliate.email %></div>
    </div>
    <div class="aff-info-card__meta">
      <div class="aff-info-card__meta-item">
        <span class="aff-info-card__meta-label">Telefone</span>
        <span class="aff-info-card__meta-value"><%= @affiliate.phone.presence || '-' %></span>
      </div>
      <div class="aff-info-card__meta-item">
        <span class="aff-info-card__meta-label">Cadastrado em</span>
        <span class="aff-info-card__meta-value"><%= @affiliate.created_at.strftime('%d/%m/%Y') %></span>
      </div>
      <div class="aff-info-card__meta-item">
        <span class="aff-info-card__meta-label">ID</span>
        <span class="aff-info-card__meta-value">#<%= @affiliate.id %></span>
      </div>
    </div>
  </div>

  <% if @affiliate.utm_code.blank? %>
    <div class="aff-empty">
      <div class="aff-empty__icon">
        <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
        </svg>
      </div>
      <h3 class="aff-empty__title">Código UTM não definido</h3>
      <p class="aff-empty__text">Este afiliado não possui um código UTM configurado. Configure um código para rastrear suas vendas.</p>
      <%= link_to edit_affiliate_path(@affiliate), class: 'aff-btn aff-btn--primary' do %>
        Configurar Código UTM
      <% end %>
    </div>
  <% elsif @total_events.to_i == 0 %>
    <div class="aff-empty">
      <div class="aff-empty__icon">
        <svg width="40" height="40" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
        </svg>
      </div>
      <h3 class="aff-empty__title">Sem dados no período</h3>
      <p class="aff-empty__text">Nenhum evento encontrado com <code>utm_affiliate=<%= @affiliate.utm_code %></code> nos últimos <%= @period %> dias.</p>
    </div>
  <% else %>

    <%# KPIs %>
    <div class="aff-kpi-grid">
      <div class="aff-kpi aff-kpi--blue">
        <div class="aff-kpi__label">Sessões Únicas</div>
        <div class="aff-kpi__value"><%= number_with_delimiter(@unique_sessions) %></div>
      </div>
      <div class="aff-kpi aff-kpi--green">
        <div class="aff-kpi__label">Total de Eventos</div>
        <div class="aff-kpi__value"><%= number_with_delimiter(@total_events) %></div>
      </div>
      <div class="aff-kpi aff-kpi--amber">
        <div class="aff-kpi__label">Produtos Vistos</div>
        <div class="aff-kpi__value"><%= number_with_delimiter(@counts[:product_viewed]) %></div>
        <div class="aff-kpi__rate"><%= @conversion[:product_viewed] %>% taxa</div>
      </div>
      <div class="aff-kpi aff-kpi--rose">
        <div class="aff-kpi__label">Add ao Carrinho</div>
        <div class="aff-kpi__value"><%= number_with_delimiter(@counts[:added_to_cart]) %></div>
        <div class="aff-kpi__rate"><%= @conversion[:added_to_cart] %>% taxa</div>
      </div>
      <div class="aff-kpi aff-kpi--purple">
        <div class="aff-kpi__label">Vendas Concluídas</div>
        <div class="aff-kpi__value"><%= number_with_delimiter(@counts[:checkout_completed]) %></div>
        <div class="aff-kpi__rate"><%= @conversion[:checkout_completed] %>% conversão</div>
      </div>
    </div>

    <%# Funil %>
    <div class="aff-funnel-section">
      <div class="aff-funnel-section__header">
        <div class="aff-funnel-section__title">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
          Funil de Conversão
        </div>
        <div class="aff-funnel-section__period">
          <svg width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>
          Últimos <%= @period %> dias
        </div>
      </div>
      <div class="aff-funnel">
        <% funnel_steps = [
          { name: 'Páginas', count: @counts[:page_viewed], color: '#3b82f6', rate: 100 },
          { name: 'Produtos', count: @counts[:product_viewed], color: '#22c55e', rate: @conversion[:product_viewed] },
          { name: 'Carrinho', count: @counts[:added_to_cart], color: '#f59e0b', rate: @conversion[:added_to_cart] },
          { name: 'Checkout', count: @counts[:checkout_started], color: '#ec4899', rate: (@counts[:page_viewed] > 0 ? (@counts[:checkout_started].to_f / @counts[:page_viewed] * 100).round(2) : 0) },
          { name: 'Venda', count: @counts[:checkout_completed], color: '#8b5cf6', rate: @conversion[:checkout_completed] }
        ] %>
        <% funnel_steps.each do |step| %>
          <div class="aff-funnel__step">
            <div class="aff-funnel__icon" style="background: <%= step[:color] %>20;">
              <svg width="20" height="20" fill="none" stroke="<%= step[:color] %>" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>
            </div>
            <div class="aff-funnel__count"><%= number_with_delimiter(step[:count]) %></div>
            <div class="aff-funnel__name"><%= step[:name] %></div>
            <div class="aff-funnel__bar">
              <div class="aff-funnel__bar-fill" style="width: <%= [step[:rate], 100].min %>%; background: <%= step[:color] %>;"></div>
            </div>
            <div class="aff-funnel__rate"><%= step[:rate] %>%</div>
          </div>
        <% end %>
      </div>
    </div>

    <%# Grid de Cards %>
    <div class="aff-grid-2">
      <%# Top Produtos %>
      <div class="aff-card">
        <div class="aff-card__header">
          <div class="aff-card__title">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>
            Produtos Mais Visitados
          </div>
        </div>
        <% if @top_products.present? %>
          <ul class="aff-top-list aff-top-list--products">
            <% @top_products.each_with_index do |product, idx| %>
              <li>
                <span class="aff-top-list__rank"><%= idx + 1 %></span>
                <% if product[:image].present? %>
                  <img src="<%= product[:image] %>" alt="" class="aff-top-list__img" loading="lazy">
                <% else %>
                  <div class="aff-top-list__img-placeholder">
                    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" /></svg>
                  </div>
                <% end %>
                <div class="aff-top-list__info">
                  <div class="aff-top-list__title"><%= truncate(product[:title], length: 40) %></div>
                  <% if product[:sku].present? %>
                    <div class="aff-top-list__sku">SKU: <%= product[:sku] %></div>
                  <% end %>
                  <% if product[:price].present? %>
                    <div class="aff-top-list__price"><%= number_to_currency(product[:price], unit: 'R$ ', separator: ',', delimiter: '.') %></div>
                  <% end %>
                </div>
                <span class="aff-top-list__count"><%= product[:count] %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="aff-card__empty">Nenhum produto visualizado</div>
        <% end %>
      </div>

      <%# Dispositivos e Referrers %>
      <div class="aff-card">
        <div class="aff-card__header">
          <div class="aff-card__title">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" /></svg>
            Dispositivos
          </div>
        </div>
        <div class="aff-devices">
          <% total_devices = @devices.values.sum.to_f %>
          <% [
            { key: :mobile, label: 'Mobile', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />', color: '#3b82f6' },
            { key: :desktop, label: 'Desktop', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0V12a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 12V5.25" />', color: '#22c55e' },
            { key: :tablet, label: 'Tablet', icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5h3m-6.75 2.25h10.5a2.25 2.25 0 002.25-2.25v-15a2.25 2.25 0 00-2.25-2.25H6.75A2.25 2.25 0 004.5 4.5v15a2.25 2.25 0 002.25 2.25z" />', color: '#f59e0b' }
          ].each do |device| %>
            <% pct = total_devices > 0 ? (@devices[device[:key]].to_f / total_devices * 100).round(1) : 0 %>
            <div class="aff-device">
              <div class="aff-device__icon" style="background: <%= device[:color] %>15; color: <%= device[:color] %>;">
                <svg width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><%= device[:icon].html_safe %></svg>
              </div>
              <div class="aff-device__info">
                <div class="aff-device__label"><%= device[:label] %></div>
                <div class="aff-device__bar">
                  <div class="aff-device__bar-fill" style="width: <%= pct %>%; background: <%= device[:color] %>;"></div>
                </div>
              </div>
              <div class="aff-device__stats">
                <div class="aff-device__count"><%= @devices[device[:key]] %></div>
                <div class="aff-device__pct"><%= pct %>%</div>
              </div>
            </div>
          <% end %>
        </div>

        <div class="aff-card__divider"></div>

        <div class="aff-card__header">
          <div class="aff-card__title">
            <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" /></svg>
            Origens do Tráfego
          </div>
        </div>
        <% if @referrers.present? %>
          <ul class="aff-top-list">
            <% @referrers.each_with_index do |(source, count), idx| %>
              <li>
                <span class="aff-top-list__rank"><%= idx + 1 %></span>
                <span class="aff-top-list__title"><%= source %></span>
                <span class="aff-top-list__count"><%= count %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <div class="aff-card__empty">Nenhuma origem identificada</div>
        <% end %>
      </div>
    </div>

    <%# Heatmap de Horários %>
    <div class="aff-card">
      <div class="aff-card__header">
        <div class="aff-card__title">
          <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
          Atividade por Horário
        </div>
      </div>
      <div class="aff-heatmap-wrap">
        <div class="aff-heatmap">
          <% max_hourly = @hourly_events.values.max.to_f %>
          <% @hourly_events.each do |hour, count| %>
            <% intensity = max_hourly > 0 ? (count / max_hourly) : 0 %>
            <% bg_color = intensity > 0.7 ? '#3b82f6' : (intensity > 0.4 ? '#93c5fd' : (intensity > 0.1 ? '#dbeafe' : '#f1f5f9')) %>
            <% text_color = intensity > 0.5 ? '#fff' : '#64748b' %>
            <div class="aff-heatmap__cell" style="background: <%= bg_color %>; color: <%= text_color %>;" data-tooltip="<%= hour %>h: <%= count %> eventos">
              <%= count > 0 ? count : '' %>
            </div>
          <% end %>
        </div>
        <div class="aff-heatmap__labels">
          <% (0..23).each do |h| %>
            <div class="aff-heatmap__label"><%= h %>h</div>
          <% end %>
        </div>
      </div>
    </div>

    <%# Sessões Recentes %>
    <div class="aff-table-card">
      <div class="aff-table-card__header">
        <div class="aff-table-card__title">Sessões Recentes</div>
        <div class="aff-table-card__count"><%= @recent_sessions.size %> sessões</div>
      </div>
      <div class="aff-table-wrap">
        <table class="aff-table">
          <thead>
            <tr>
              <th>Sessão</th>
              <th>Início</th>
              <th>Duração</th>
              <th class="center">Eventos</th>
              <th>Etapas</th>
              <th class="center">Status</th>
            </tr>
          </thead>
          <tbody>
            <% @recent_sessions.each do |session| %>
              <tr class="<%= 'aff-table__row--converted' if session[:converted] %>">
                <td>
                  <span class="aff-badge aff-badge--mono"><%= session[:session_id].to_s[0..7] %>...</span>
                </td>
                <td><%= session[:started_at]&.strftime('%d/%m %H:%M') %></td>
                <td><%= session[:duration_min] %> min</td>
                <td class="center">
                  <span class="aff-badge aff-badge--count"><%= session[:event_count] %></span>
                </td>
                <td>
                  <div class="aff-session-kinds">
                    <% session[:kinds].each do |kind| %>
                      <% badge_class = case kind
                        when 'page_viewed' then 'aff-badge--page'
                        when 'product_viewed' then 'aff-badge--product'
                        when 'product_added_to_cart' then 'aff-badge--cart'
                        when 'checkout_started', 'checkout_completed' then 'aff-badge--checkout'
                        else 'aff-badge--mono'
                      end %>
                      <span class="aff-badge <%= badge_class %>"><%= kind.split('_').first.capitalize %></span>
                    <% end %>
                  </div>
                </td>
                <td class="center">
                  <% if session[:converted] %>
                    <span class="aff-badge aff-badge--success">Convertido</span>
                  <% else %>
                    <span class="aff-badge aff-badge--warning">Abandonado</span>
                  <% end %>
                </td>
              </tr>
            <% end %>
            <% if @recent_sessions.empty? %>
              <tr>
                <td colspan="6" class="aff-table__empty">Nenhuma sessão encontrada</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

  <% end %>

</div>

<style>
  .aff-page { padding: 24px 28px; min-height: 100vh; }
  @media (max-width: 600px) { .aff-page { padding: 16px; } }

  .aff-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 24px;
    background: #fff;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 18px 24px;
  }
  .aff-header__left { display: flex; flex-direction: column; gap: 4px; }
  .aff-header__breadcrumb { display: flex; align-items: center; gap: 8px; font-size: 13px; color: #64748b; }
  .aff-header__back-link { display: flex; align-items: center; gap: 4px; color: #3b82f6; text-decoration: none; font-weight: 500; }
  .aff-header__back-link:hover { text-decoration: underline; }
  .aff-header__name { font-weight: 600; color: #0f172a; }
  .aff-header__title { font-size: 20px; font-weight: 800; color: #0f172a; margin: 8px 0 4px; }
  .aff-header__subtitle { font-size: 13px; color: #64748b; margin: 0; }
  .aff-utm-code { background: #dbeafe; color: #1d4ed8; padding: 2px 8px; border-radius: 4px; font-family: monospace; font-size: 12px; }
  .aff-header__right { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }

  .aff-filters { display: flex; gap: 4px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: 4px; }
  .aff-filter-btn { padding: 6px 14px; border-radius: 7px; background: transparent; color: #64748b; font-size: 13px; font-weight: 500; text-decoration: none; transition: all .15s; }
  .aff-filter-btn:hover { background: #fff; color: #1e293b; }
  .aff-filter-btn--active { background: #fff; color: #0f172a; font-weight: 600; box-shadow: 0 1px 4px rgba(0,0,0,.08); }

